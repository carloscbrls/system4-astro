---
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  schema?: object | object[];
}

const { title, description = 'System4 of San Joaquin Valley — Commercial cleaning, janitorial, and facility services for medical, dental, office, and multi-site organizations across the Central Valley. One contact. One invoice. One solution.', canonicalUrl, schema } = Astro.props;

const currentYear = new Date().getFullYear();

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "System4 of San Joaquin Valley",
  "description": "Commercial cleaning, janitorial, and facility services for medical, dental, office, and multi-site organizations across the San Joaquin Valley and Stanislaus County. One contact. One invoice. One solution.",
  "url": "https://system4sjv.com",
  "telephone": "+1-209-229-2066",
  "email": "jcastillo@system4.com",
  "areaServed": [
    { "@type": "City", "name": "Stockton" },
    { "@type": "City", "name": "Modesto" },
    { "@type": "City", "name": "Tracy" },
    { "@type": "City", "name": "Manteca" },
    { "@type": "City", "name": "Lodi" },
    { "@type": "City", "name": "Turlock" },
    { "@type": "AdministrativeArea", "name": "San Joaquin County" },
    { "@type": "AdministrativeArea", "name": "Stanislaus County" }
  ],
  "serviceType": ["Commercial Cleaning", "Janitorial Services", "Facility Maintenance", "Medical Office Cleaning", "Dental Office Cleaning", "Day Porter Services", "Floor Care", "Disinfection Services"]
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#1a2e4a" />
  <meta name="format-detection" content="telephone=yes" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="System4 of San Joaquin Valley" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Inter+Tight:opsz,wght@14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
  <link rel="icon" type="image/png" href="/favicon-180.png" sizes="180x180" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="msapplication-TileColor" content="#1a2e4a" />
  <script type="application/ld+json" set:html={JSON.stringify(schema || localBusinessSchema)} />
  <style>
    :root{--navy:#1a2e4a;--blue:#0b7dda;--blue-dark:#0a5ea8;--blue-light:#2d9cff;--blue-500:#3d8fd4;--blue-600:#0b7dda;--blue-700:#0a5ea8;--blue-800:#083f71;--blue-900:#1a2e4a;--blue-100:#e8f4fd;--magenta:#d4376e;--magenta-dark:#b02a58;--green-600:#28a866;--green-500:#1d9a56;--green-100:#d1fae5;--gray-900:#111827;--gray-700:#374151;--gray-500:#6b7280;--gray-300:#d1d5db;--gray-100:#f3f4f6;--gray-50:#f8f9fb;--white:#fff;--font-display:'DM Serif Display',Georgia,'Times New Roman',serif;--font-body:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;--font-tight:'Inter Tight',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;--radius-sm:8px;--radius-md:10px;--radius-lg:16px;--shadow-sm:0 1px 3px rgba(0,0,0,.08);--shadow-md:0 4px 12px rgba(0,0,0,.1);--shadow-lg:0 12px 32px rgba(0,0,0,.12);--transition:all .3s ease}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--font-body);color:var(--gray-900);line-height:1.75;letter-spacing:-.01em;-webkit-font-smoothing:antialiased}
    img{max-width:100%;height:auto;display:block}
    a{color:var(--blue-600);text-decoration:none;transition:var(--transition)}
    a:hover{color:var(--blue-700)}
    a:focus-visible,button:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .skip-link{position:absolute;top:-100%;left:0;background:var(--blue);color:var(--white);padding:.75rem 1.5rem;z-index:9999;font-weight:600;border-radius:0 0 var(--radius-sm) 0}
    .skip-link:focus{top:0}
    .container{max-width:1200px;margin:0 auto;padding:0 1.5rem}
    .nav{background:var(--white);border-bottom:1px solid var(--gray-100);position:sticky;top:0;z-index:100}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;max-width:1200px;margin:0 auto}
    .nav-logo{display:flex;align-items:center;gap:.5rem;text-decoration:none}
    .nav-logo img{height:36px;width:auto}
    .nav-logo-text{font-family:var(--font-tight);font-size:.75rem;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--gray-500);line-height:1.2}
    .nav-links{display:flex;gap:2rem;align-items:center}
    .nav-links a{color:var(--gray-700);font-weight:500;font-size:.95rem;padding:.35rem .85rem;min-height:44px;display:inline-flex;align-items:center;border-radius:8px;transition:all .3s cubic-bezier(.25,.46,.45,.94);position:relative}
    .nav-links a::after{content:"";position:absolute;bottom:4px;left:50%;transform:translateX(-50%) scaleX(0);width:calc(100% - 1.7rem);height:2px;background:var(--magenta);border-radius:1px;transition:transform .3s cubic-bezier(.25,.46,.45,.94)}
    .nav-links a:hover{color:var(--navy);background:var(--gray-50)}
    .nav-links a:hover::after{transform:translateX(-50%) scaleX(1)}
    .nav-links a:focus-visible{outline:3px solid var(--blue);outline-offset:2px;border-radius:8px}
    .nav-cta{background:linear-gradient(135deg,var(--magenta),#e8447a);color:var(--white);padding:.6rem 1.4rem;border-radius:8px;font-weight:600;border:none;box-shadow:0 2px 8px rgba(212,55,110,.25);transition:all .3s cubic-bezier(.25,.46,.45,.94);position:relative;overflow:hidden}
    .nav-cta::before{content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transition:left .5s ease}
    .nav-cta:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(212,55,110,.4);color:var(--white)}
    .nav-cta:hover::before{left:100%}
    .nav-phone{font-weight:700;color:var(--navy);white-space:nowrap}
    .mobile-toggle{display:none;background:none;border:none;cursor:pointer;padding:.5rem;min-width:44px;min-height:44px;align-items:center;justify-content:center;color:var(--navy)}
    .btn-primary{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,var(--magenta) 0%,#e8447a 50%,var(--magenta) 100%);background-size:200% auto;color:var(--white);padding:.85rem 2.25rem;border-radius:12px;font-weight:600;font-size:1rem;transition:all .4s cubic-bezier(.25,.46,.45,.94);box-shadow:0 4px 16px rgba(212,55,110,.35),inset 0 1px 0 rgba(255,255,255,.2);text-decoration:none;border:none;cursor:pointer;letter-spacing:.01em;position:relative;overflow:hidden}
    .btn-primary::before{content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transition:left .6s ease}
    .btn-primary:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(212,55,110,.45),inset 0 1px 0 rgba(255,255,255,.25);background-position:right center}
    .btn-primary:hover::before{left:100%}
    .btn-primary:active{transform:translateY(-1px);box-shadow:0 4px 12px rgba(212,55,110,.3)}
    .btn-primary:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .btn-secondary{display:inline-flex;align-items:center;gap:.5rem;background:transparent;color:var(--white);padding:.85rem 2.25rem;border-radius:12px;font-weight:600;font-size:1rem;border:2px solid rgba(255,255,255,.4);transition:all .4s cubic-bezier(.25,.46,.45,.94);text-decoration:none;cursor:pointer;letter-spacing:.01em;position:relative;overflow:hidden}
    .btn-secondary::before{content:"";position:absolute;inset:0;background:rgba(255,255,255,.08);opacity:0;transition:opacity .3s ease}
    .btn-secondary:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.7);transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.2);color:var(--white)}
    .btn-secondary:hover::before{opacity:1}
    .btn-secondary:active{transform:translateY(-1px)}
    .btn-secondary:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .hero{background:linear-gradient(135deg,#1a2e4a,#0b7dda);color:var(--white);padding:4rem 1.5rem 3rem;text-align:center;position:relative;overflow:hidden}
    .hero-compact{padding:3rem 1.5rem 2rem}
    .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 30% 50%,rgba(16,108,176,.2),transparent 70%)}
    .hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:.15;z-index:0}
    .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,5vw,3.5rem);margin-bottom:1rem;position:relative;font-weight:400;color:white;-webkit-text-fill-color:white;line-height:1.1;letter-spacing:-.02em}
    .hero h1 em{font-style:italic;color:var(--blue-light);-webkit-text-fill-color:var(--blue-light)}
    .hero p{font-size:1.15rem;line-height:1.8;max-width:680px;margin:0 auto 2rem;opacity:.9;position:relative;color:white;-webkit-text-fill-color:white}
    .hero-badges{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;margin-top:2rem;position:relative}
    .hero-badge{background:rgba(255,255,255,.08);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.18);border-radius:var(--radius-md);padding:1rem 1.5rem;text-align:center;color:white;-webkit-text-fill-color:white;transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative}
    .hero-badge::before{content:"";position:absolute;inset:-1px;border-radius:inherit;padding:1px;background:linear-gradient(135deg,rgba(255,255,255,.3),transparent,rgba(255,255,255,.15));-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none}
    .hero-badge:hover{background:rgba(255,255,255,.14);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.15)}
    .hero-badge strong{display:block;font-size:1.8rem;font-family:var(--font-display);color:white;-webkit-text-fill-color:white;font-weight:400;letter-spacing:-.01em}
    .hero-badge span{font-size:.8rem;opacity:.8;text-transform:uppercase;letter-spacing:.08em;color:white;-webkit-text-fill-color:white}
    .hero-cta{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;position:relative}
    .section{padding:5rem 1.5rem}
    .section-alt{background:var(--gray-50)}
    .section-label{color:var(--green-600);-webkit-text-fill-color:var(--green-600);font-weight:700;font-size:.85rem;text-transform:uppercase;letter-spacing:.12em;margin-bottom:.5rem;display:inline-flex;align-items:center;gap:.5rem}
    .section-label::before{content:"";width:24px;height:2px;background:var(--magenta);border-radius:1px}
    .section-title{font-family:var(--font-display);font-size:clamp(1.8rem,3vw,2.5rem);color:var(--gray-900);margin-bottom:1rem;line-height:1.15;font-weight:400;letter-spacing:-.01em}
    .section-subtitle{color:var(--gray-500);font-size:1.05rem;max-width:600px;line-height:1.7}
    .card-grid{display:grid;gap:1.5rem;margin-top:2.5rem}
    .card-grid-3{grid-template-columns:repeat(3,1fr)}
    .card{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);padding:2rem;transition:all .4s cubic-bezier(.25,.46,.45,.94);text-decoration:none;color:inherit;position:relative;overflow:hidden}
    .card::after{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--magenta),var(--blue));transform:scaleX(0);transform-origin:left;transition:transform .4s cubic-bezier(.25,.46,.45,.94)}
    .card:hover{box-shadow:0 12px 40px rgba(0,0,0,.1);transform:translateY(-6px);border-color:var(--blue-100)}
    .card:hover::after{transform:scaleX(1)}
    .card:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .card h3{color:var(--gray-900)}
    .card p{color:var(--gray-500)}
    .card-icon{width:48px;height:48px;background:linear-gradient(135deg,var(--blue-600),var(--blue-800));border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;box-shadow:0 4px 12px rgba(16,108,176,.25);transition:all .4s cubic-bezier(.25,.46,.45,.94)}
    .card:hover .card-icon{transform:scale(1.08);box-shadow:0 6px 18px rgba(16,108,176,.35)}
    .card-icon svg{color:white}
    .card h3{font-family:var(--font-tight);font-size:1.2rem;margin-bottom:.5rem;color:var(--gray-900);font-weight:600}
    .card p{color:var(--gray-500);font-size:.92rem;line-height:1.6}
    .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2.5rem;margin-top:2.5rem}
    .step{text-align:center}
    .step-number{width:56px;height:56px;background:linear-gradient(135deg,var(--green-600),var(--green-500));color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-tight);font-size:1.5rem;margin:0 auto 1rem;box-shadow:0 4px 14px rgba(40,168,102,.35);transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative}
    .step-number::after{content:"";position:absolute;inset:-3px;border-radius:50%;border:2px solid rgba(40,168,102,.25);transition:all .4s cubic-bezier(.25,.46,.45,.94)}
    .step:hover .step-number{transform:scale(1.08);box-shadow:0 8px 24px rgba(40,168,102,.4)}
    .step:hover .step-number::after{border-color:rgba(40,168,102,.5);inset:-6px}
    .step h3{font-family:var(--font-body);font-size:1.2rem;margin-bottom:.5rem;font-weight:600}
    .step p{color:var(--gray-500);font-size:.92rem}
    .industry-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:2.5rem}
    .industry-card{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);overflow:hidden;transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative}
    .industry-card::after{content:"";position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--magenta),var(--blue));transform:scaleX(0);transition:transform .4s cubic-bezier(.25,.46,.45,.94)}
    .industry-card:hover{box-shadow:0 16px 48px rgba(0,0,0,.12);transform:translateY(-6px)}
    .industry-card:hover::after{transform:scaleX(1)}
    .industry-card img{width:100%;height:180px;object-fit:cover}.industry-card-body{padding:1.5rem}
    .industry-card h3{font-family:var(--font-tight);font-size:1.15rem;margin-bottom:.5rem;color:var(--gray-900);font-weight:600}
    .industry-card p{color:var(--gray-500);font-size:.88rem;line-height:1.6}
    .areas-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:2rem}
    .area-card{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-md);padding:1.25rem 1.5rem;display:flex;align-items:center;gap:.75rem;transition:all .35s cubic-bezier(.25,.46,.45,.94);position:relative;overflow:hidden}
    .area-card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--blue),var(--magenta));opacity:0;transition:opacity .35s ease}
    .area-card:hover{border-color:var(--blue-100);box-shadow:0 8px 24px rgba(0,0,0,.08);transform:translateX(4px)}
    .area-card:hover::before{opacity:1}
    .area-card svg{color:var(--green-600);flex-shrink:0;transition:transform .3s ease}
    .area-card:hover svg{transform:scale(1.15)}
    .area-card strong{color:var(--gray-900);font-size:1rem}
    .area-card span{color:var(--gray-500);font-size:.85rem}
    .cta-section{background:linear-gradient(135deg,var(--magenta) 0%,#e8447a 40%,#c42d63 100%);padding:4rem 1.5rem;text-align:center;color:white;position:relative;overflow:hidden}
    .cta-section::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 80%,rgba(255,255,255,.08),transparent 60%),radial-gradient(circle at 80% 20%,rgba(255,255,255,.05),transparent 50%);pointer-events:none}
    .cta-section .container{position:relative;z-index:1}
    .cta-section h2{font-family:var(--font-display);font-size:clamp(1.8rem,3vw,2.5rem);margin-bottom:1rem;font-weight:700;color:white;-webkit-text-fill-color:white;letter-spacing:-.01em}
    .cta-section p{opacity:.9;max-width:600px;margin:0 auto 2rem;line-height:1.7;color:white;-webkit-text-fill-color:white}
    .cta-section .btn-primary{background:white;color:var(--magenta);box-shadow:0 4px 14px rgba(0,0,0,.15);position:relative;overflow:hidden}
    .cta-section .btn-primary::before{content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(212,55,110,.1),transparent);transition:left .6s ease}
    .cta-section .btn-primary:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.25);color:var(--magenta-dark)}
    .cta-section .btn-primary:hover::before{left:100%}
    .cta-section .btn-secondary{background:transparent;color:white;border-color:rgba(255,255,255,.5)}
    .cta-section .btn-secondary:hover{background:rgba(255,255,255,.15);border-color:white}
    .footer{background:var(--navy);color:rgba(255,255,255,.7);padding:3rem 1.5rem 2rem}
    .footer-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:2rem}
    .footer h4,.footer-heading{color:white;font-family:var(--font-display);margin-bottom:1rem;-webkit-text-fill-color:white}
    .footer a{color:rgba(255,255,255,.8);text-decoration:none;border-radius:2px;padding:0 2px;transition:all .3s cubic-bezier(.25,.46,.45,.94)}
    .footer a:hover{color:white;background:rgba(255,255,255,.1)}
    .footer a:focus-visible{outline:2px solid var(--blue-light);outline-offset:2px}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.1);margin-top:2rem;padding-top:1.5rem;text-align:center;font-size:.85rem}
    [data-animate]{opacity:0;transform:translateY(30px);transition:opacity .7s cubic-bezier(.25,.46,.45,.94),transform .7s cubic-bezier(.25,.46,.45,.94)}
    [data-animate].visible{opacity:1;transform:translateY(0)}
    [data-animate]:nth-child(2){transition-delay:.1s}
    [data-animate]:nth-child(3){transition-delay:.2s}
    [data-animate]:nth-child(4){transition-delay:.3s}
    [data-animate]:nth-child(5){transition-delay:.35s}
    [data-animate]:nth-child(6){transition-delay:.4s}
    @media(max-width:1024px){.card-grid-3{grid-template-columns:repeat(2,1fr)}.industry-grid{grid-template-columns:repeat(2,1fr)}.steps{grid-template-columns:repeat(2,1fr)}.areas-grid{grid-template-columns:repeat(2,1fr)}.trust-inner{grid-template-columns:1fr}.footer-inner{grid-template-columns:1fr 1fr}.nav-links{gap:1.5rem}}
    @media(max-width:768px){.nav-links{display:none;flex-direction:column;position:absolute;top:100%;left:0;right:0;background:var(--white);padding:1rem 1.5rem;box-shadow:var(--shadow-md);z-index:99;gap:.5rem;border-bottom-left-radius:var(--radius-md);border-bottom-right-radius:var(--radius-md)}.nav-links.open{display:flex}.nav-links a{padding:.75rem 0;border-bottom:1px solid var(--gray-100)}.nav-links a:last-child{border-bottom:none}.mobile-toggle{display:flex}.card-grid-3{grid-template-columns:1fr}.steps{grid-template-columns:1fr}.industry-grid{grid-template-columns:1fr}.areas-grid{grid-template-columns:1fr}.footer-inner{grid-template-columns:1fr}.hero{padding:2.5rem 1rem 1.5rem}.hero-compact{padding:2rem 1rem 1.25rem}.hero h1{font-size:1.6rem;margin-bottom:.75rem}.hero p{font-size:1rem;margin-bottom:1rem}.hero-badges{flex-direction:row;gap:.75rem;margin-top:1rem}.hero-badge{padding:.6rem 1rem}.hero-badge strong{font-size:1.3rem}.hero-badge span{font-size:.7rem}.hero-inner{grid-template-columns:1fr!important}.hero-form-wrap{width:100%}.hero-form{padding:1.25rem}.industry-card img{height:140px}.stat{padding:.75rem 0}.stat-number{font-size:2rem}.section{padding:3rem 1rem}}
