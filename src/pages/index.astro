---
import Layout from '../layouts/Layout.astro';

const title = 'Commercial Cleaning & Facility Services | System4 of San Joaquin Valley';
const description = 'System4 of San Joaquin Valley — DGS-certified commercial cleaning, janitorial, and facility services for medical, dental, office, and multi-site organizations across Stockton, Modesto, Tracy, Manteca, Lodi, and Turlock. One contact. One invoice. One solution.';
const canonicalUrl = 'https://system4sjv.com/';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "System4 of San Joaquin Valley",
  "image": "https://system4sjv.com/favicon-32.png",
  "telephone": "+1-209-229-2066",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "672 W 11th St Ste 342",
    "addressLocality": "Tracy",
    "addressRegion": "CA",
    "postalCode": "95376",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "6"
  },
  "review": [
    {
      "@type": "Review",
      "author": {"@type": "Person", "name": "Benjamin Kegele"},
      "reviewRating": {"@type": "Rating", "ratingValue": "5"},
      "reviewBody": "Very professional service and great to work with!"
    },
    {
      "@type": "Review",
      "author": {"@type": "Person", "name": "Josh Rangel"},
      "reviewRating": {"@type": "Rating", "ratingValue": "5"},
      "reviewBody": "Hands down best quality service and professionalism!"
    },
    {
      "@type": "Review",
      "author": {"@type": "Person", "name": "Nicco Franco"},
      "reviewRating": {"@type": "Rating", "ratingValue": "5"},
      "reviewBody": "System 4 did a great job cleaning our carpets!"
    }
  ],
  
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What commercial cleaning services does System4 offer in San Joaquin Valley?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "System4 of San Joaquin Valley offers commercial cleaning, janitorial services, day porter services, floor care and maintenance, high-touch disinfection, and specialized medical office cleaning. We serve offices, medical and dental facilities, banks, car dealerships, schools, and warehouses across Stockton, Modesto, Tracy, Manteca, Lodi, and Turlock."
      }
    },
    {
      "@type": "Question",
      "name": "Does System4 require long-term contracts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. System4 of San Joaquin Valley does not require long-term contracts. We earn your business every day with consistent results, regular quality inspections, and a dedicated territory manager."
      }
    },
    {
      "@type": "Question",
      "name": "What areas does System4 of San Joaquin Valley serve?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We serve Stockton, Modesto, Tracy, Manteca, Lodi, Turlock, and all of San Joaquin County and Stanislaus County in California's Central Valley."
      }
    },
    {
      "@type": "Question",
      "name": "Is System4 a DGS certified business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. System4 holds DGS Certification ID 2022081, qualifying us for state and government facility cleaning contracts."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can System4 provide a cleaning quote?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We typically deliver a custom cleaning proposal within 24 hours of a facility walkthrough. Contact us at (209) 229-2066 or jcastillo@system4.com for a free, no-obligation quote."
      }
    }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={faqSchema}>

  <!-- Hero -->
  <section class="hero" data-animate>
    <img src="/images/hero-office.jpg" alt="Clean modern office lobby" class="hero-bg" loading="eager" />
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-tag">DGS Cert. ID 2022081</div>
        <h1>Commercial Cleaning &<br/>Facility Services in the <em>San Joaquin Valley</em></h1>
        <p class="hero-tagline">Pure Clean. Proven Maintenance. One Partner.</p>
        <p class="hero-sub">System4 delivers customized cleaning programs for medical offices, dental practices, professional offices, and multi-site organizations — with the resources of a national company and the attention of a local partner.</p>
        <div class="hero-cta">
          <a href="/contact/" class="btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Get a Free Quote
          </a>
          <a href="tel:+12092292066" class="btn-secondary btn-lg" style="-webkit-text-fill-color:#d4376e;color:#d4376e;background:white;border-color:white;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (209) 229-2066
          </a>
        </div>
        <div class="hero-badges">
          <div class="hero-badge">
            <span class="badge-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span class="badge-accent">One</span>
            <span class="badge-label">Contact</span>
          </div>
          <div class="hero-badge">
            <span class="badge-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </span>
            <span class="badge-accent">One</span>
            <span class="badge-label">Invoice</span>
          </div>
          <div class="hero-badge">
            <span class="badge-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </span>
            <span class="badge-accent">One</span>
            <span class="badge-label">Solution</span>
          </div>
        </div>
      </div>
      <!-- Desktop form (shown only on wide screens, side-by-side with hero content) -->
      <div class="hero-form-desktop">
        <form class="hero-form" name="contact-desktop" method="POST" data-netlify="true" action="/contact/thanks/">
          <input type="hidden" name="form-name" value="contact-desktop" />
          <h2 class="hero-form-title">Get Your Free Quote</h2>
          <p style="color:var(--gray-500);font-size:.88rem;margin-bottom:1.25rem;">Tell us about your facility. We'll respond within 24 hours.</p>
          <label for="quote-name-d" class="sr-only">Full Name</label>
          <input type="text" id="quote-name-d" name="name" placeholder="Full Name *" required aria-required="true" autocomplete="name" />
          <label for="quote-email-d" class="sr-only">Email Address</label>
          <input type="email" id="quote-email-d" name="email" placeholder="Email Address *" required aria-required="true" autocomplete="email" />
          <label for="quote-phone-d" class="sr-only">Phone Number</label>
          <input type="tel" id="quote-phone-d" name="phone" placeholder="Phone Number" autocomplete="tel" />
          <label for="quote-service-d" class="sr-only">Select a Service</label>
          <select id="quote-service-d" name="service" aria-label="Select a service type" autocomplete="off">
            <option value="" disabled selected>Select a Service</option>
            <option value="commercial-cleaning">Commercial & Office Cleaning</option>
            <option value="medical-dental">Medical & Dental Office Cleaning</option>
            <option value="janitorial">Janitorial Services</option>
            <option value="day-porter">Day Porter Services</option>
            <option value="floor-care">Floor Care & Carpet</option>
            <option value="disinfection">High-Touch Disinfection</option>
            <option value="other">Other / Custom</option>
          </select>
          <label for="quote-city-d" class="sr-only">City</label>
          <input type="text" id="quote-city-d" name="city" placeholder="City (e.g. Stockton, Modesto)" />
          <button type="submit" class="btn-primary btn-block">Get a Free Quote</button>
          <p class="hero-form-disclaimer">By submitting, you agree to be contacted about your request.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Quote form — separate section for mobile, overlaps hero on desktop -->
  <section class="hero-form-section" data-animate>
    <div class="container">
      <div class="hero-form-wrap">
        <form class="hero-form" name="contact" method="POST" data-netlify="true" action="/contact/thanks/">
          <h2 class="hero-form-title">Get Your Free Quote</h2>
          <p style="color:var(--gray-500);font-size:.88rem;margin-bottom:1.25rem;">Tell us about your facility. We'll respond within 24 hours.</p>
          <label for="quote-name" class="sr-only">Full Name</label>
          <input type="text" id="quote-name" name="name" placeholder="Full Name *" required aria-required="true" autocomplete="name" />
          <label for="quote-email" class="sr-only">Email Address</label>
          <input type="email" id="quote-email" name="email" placeholder="Email Address *" required aria-required="true" autocomplete="email" />
          <label for="quote-phone" class="sr-only">Phone Number</label>
          <input type="tel" id="quote-phone" name="phone" placeholder="Phone Number" autocomplete="tel" />
          <label for="quote-service" class="sr-only">Select a Service</label>
          <select id="quote-service" name="service" aria-label="Select a service type" autocomplete="off">
            <option value="" disabled selected>Select a Service</option>
            <option value="commercial-cleaning">Commercial & Office Cleaning</option>
            <option value="medical-dental">Medical & Dental Office Cleaning</option>
            <option value="janitorial">Janitorial Services</option>
            <option value="day-porter">Day Porter Services</option>
            <option value="floor-care">Floor Care & Carpet</option>
            <option value="disinfection">High-Touch Disinfection</option>
            <option value="other">Other / Custom</option>
          </select>
          <label for="quote-city" class="sr-only">City</label>
          <input type="text" id="quote-city" name="city" placeholder="City (e.g. Stockton, Modesto)" />
          <button type="submit" class="btn-primary btn-block">Get a Free Quote</button>
          <p class="hero-form-disclaimer">By submitting, you agree to be contacted about your request.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Trust Stats -->
  <section class="stats-bar" data-animate>
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-number">20+</span>
        <span class="stat-label">Years of Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">67+</span>
        <span class="stat-label">System4 Locations Nationwide</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">100K+</span>
        <span class="stat-label">Clients Served</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">500K+</span>
        <span class="stat-label">Jobs Completed</span>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Our Services</div>
      <h2 class="section-title">Commercial Cleaning Services</h2>
      <p class="section-subtitle">Whether you manage a single office or a multi-site portfolio, we build a customized program that supports consistent results, reliable communication, and flexible adjustments as needs change.</p>
      <div class="card-grid card-grid-3">
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial & Office Cleaning</h3>
          <p>Routine and nightly cleaning programs for professional offices and multi-tenant buildings.</p>
        </a>
        <a href="/industries/medical-dental/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Office Cleaning</h3>
          <p>Healthcare-focused cleaning supporting infection-control best practices and consistency.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Janitorial Services</h3>
          <p>Reliable service including restrooms, trash removal, dusting, break rooms, and floor care.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Day Porter Services</h3>
          <p>Daytime upkeep for lobbies, restrooms, and high-traffic areas to keep spaces client-ready.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Floor Care & Carpet Maintenance</h3>
          <p>Strip & wax, scrub & recoat, carpet care, and ongoing floor maintenance programs.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>High-Touch Disinfection</h3>
          <p>High-touch point focus for doors, switches, restrooms, break rooms, and common areas.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Client Testimonials</div>
      <h2 class="section-title">Trusted by Facility Managers Across the Valley</h2>
      <p class="section-subtitle">Real feedback from real clients — not reviews you have to chase.</p>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem">
        <div class="card" data-animate>
          <div style="display:flex;gap:.25rem;margin-bottom:.75rem;color:var(--gold);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <p style="color:var(--gray-700);font-size:1rem;line-height:1.7;margin-bottom:1.25rem;font-style:italic;">\"We switched from an unreliable local service to System4 and the difference was immediate. Our territory manager checks in weekly and we haven\'t had a single complaint in six months.\"</p>
          <div style="display:flex;align-items:center;gap:.75rem">
            <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--blue-600),var(--navy));display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:.9rem;font-family:var(--font-tight)">DM</div>
            <div>
              <strong style="display:block;color:var(--gray-900);font-size:.95rem">David M.</strong>
              <span style="color:var(--gray-500);font-size:.85rem">Facility Manager — Medical Office Building, Stockton</span>
            </div>
          </div>
        </div>
        <div class="card" data-animate>
          <div style="display:flex;gap:.25rem;margin-bottom:.75rem;color:var(--gold);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <p style="color:var(--gray-700);font-size:1rem;line-height:1.7;margin-bottom:1.25rem;font-style:italic;">\"Having one point of contact changed everything. Before System4, I was managing three different vendors across five locations. Now I make one call and it\'s handled. The quality inspections give me peace of mind.\"</p>
          <div style="display:flex;align-items:center;gap:.75rem">
            <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--green-600),var(--green-500));display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:.9rem;font-family:var(--font-tight)">SR</div>
            <div>
              <strong style="display:block;color:var(--gray-900);font-size:.95rem">Sarah R.</strong>
              <span style="color:var(--gray-500);font-size:.85rem">Operations Director — Multi-site Portfolio, Modesto</span>
            </div>
          </div>
        </div>
        <div class="card" data-animate>
          <div style="display:flex;gap:.25rem;margin-bottom:.75rem;color:var(--gold);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
