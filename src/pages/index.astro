---
import Layout from '../layouts/Layout.astro';

const title = 'Commercial Cleaning & Facility Services | System4 of San Joaquin Valley';
const description = 'System4 of San Joaquin Valley provides commercial cleaning, janitorial, and facility services for medical, dental, offices, and multi-site organizations across the Central Valley. One contact. One invoice. One solution.';
const canonicalUrl = 'https://system4sjv.com/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero -->
  <section class="hero" data-animate>
    <div class="container">
      <h1>Commercial Cleaning &<br/>Facility Services in the <em>San Joaquin Valley</em></h1>
      <p>System4 of San Joaquin Valley delivers customized commercial cleaning, janitorial, and facility services for medical, dental, office, and multi-site organizations across the Central Valley. One contact. One invoice. One solution.</p>
      <div class="hero-cta">
        <a href="/contact/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Request a Walkthrough
        </a>
        <a href="tel:+12092292066" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (209) 229-2066
        </a>
      </div>
      <div class="hero-badges">
        <div class="hero-badge"><strong>One</strong><span>Contact</span></div>
        <div class="hero-badge"><strong>One</strong><span>Invoice</span></div>
        <div class="hero-badge"><strong>One</strong><span>Solution</span></div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Our Services</div>
      <h2 class="section-title">Commercial Cleaning Services</h2>
      <p class="section-subtitle">Whether you manage a single office or a multi-site portfolio, we build a customized program that supports consistent results, reliable communication, and flexible adjustments as needs change.</p>
      <div class="card-grid card-grid-3">
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial & Office Cleaning</h3>
          <p>Routine and nightly cleaning programs for professional offices and multi-tenant buildings.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Office Cleaning</h3>
          <p>Healthcare-focused cleaning supporting infection-control best practices and consistency.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Janitorial Services</h3>
          <p>Reliable service including restrooms, trash removal, dusting, break rooms, and floor care.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Day Porter Services</h3>
          <p>Daytime upkeep for lobbies, restrooms, and high-traffic areas to keep spaces client-ready.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Floor Care & Carpet Maintenance</h3>
          <p>Strip & wax, scrub & recoat, carpet care, and ongoing floor maintenance programs.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>High-Touch Disinfection</h3>
          <p>High-touch point focus for doors, switches, restrooms, break rooms, and common areas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why System4 -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">Why System4</div>
      <h2 class="section-title">Why Facility Managers Choose System4</h2>
      <div class="steps">
        <div class="step" data-animate><div class="step-number">1</div><h3>Dedicated Support + Clear Communication</h3><p>Work with a single point of contact to resolve issues quickly and keep service consistent.</p></div>
        <div class="step" data-animate><div class="step-number">2</div><h3>Quality Assurance Inspections</h3><p>Routine checks help maintain standards and make adjustments before small issues grow.</p></div>
        <div class="step" data-animate><div class="step-number">3</div><h3>Customized & Flexible Programs</h3><p>We tailor service frequency and timing so your operations run smoothly. As your facility changes, your cleaning program can change too.</p></div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Industries</div>
      <h2 class="section-title">Industries We Serve</h2>
      <p class="section-subtitle">Trusted by facility managers who need consistent service, responsive communication, and accountability.</p>
      <div class="industry-grid">
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏥 Medical & Dental Offices</h3><p>Cleaning programs designed for busy healthcare environments.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏢 Professional Offices</h3><p>Keep client-facing spaces spotless and ready for meetings.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🎓 Education & Schools</h3><p>Support for classrooms, offices, and common areas on your schedule.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🚗 Dealerships & Showrooms</h3><p>Presentation-focused cleaning to help spaces shine.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏦 Banks & Financial</h3><p>Detail-oriented cleaning for high-traffic, customer-facing areas.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏭 Warehouses & Light Industrial</h3><p>Practical cleaning solutions for back-of-house environments.</p></div></div>
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">Local Service</div>
      <h2 class="section-title">Serving the San Joaquin Valley</h2>
      <p class="section-subtitle">Service areas: Stockton, Modesto, Tracy, Manteca, Lodi, and the greater San Joaquin Valley.</p>
      <div class="areas-grid">
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Stockton</strong><br/><span>San Joaquin County seat — daily routes</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Modesto</strong><br/><span>Stanislaus County — full service coverage</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Tracy</strong><br/><span>Fast-growing community — flexible scheduling</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Manteca</strong><br/><span>Central location — fast response times</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Lodi</strong><br/><span>Wine country businesses — specialty care</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Turlock</strong><br/><span>Stanislaus County — medical and office focus</span></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Request a Walkthrough or Proposal</h2>
      <p>Tell us about your facility and we'll design a customized cleaning program. For faster quotes, include city, approximate square footage, and service frequency.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-secondary">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>