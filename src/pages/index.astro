---
import Layout from '../layouts/Layout.astro';

const title = 'System4 — Commercial Cleaning & Facility Services | San Joaquin Valley & Stanislaus County';
const description = 'Commercial cleaning, janitorial services, and facility maintenance for San Joaquin County and Stanislaus County businesses. Medical offices, dental clinics, commercial spaces. Call for a free quote.';
const canonicalUrl = 'https://system4.com/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero -->
  <section class="hero" data-animate>
    <div class="container">
      <h1>Commercial Cleaning &<br/>Facility Services in the <em>San Joaquin Valley</em></h1>
      <p>One partner for all your cleaning, maintenance, and facility needs across San Joaquin County and Stanislaus County. Medical offices, dental clinics, commercial buildings — we keep your space clean, safe, and ready for business.</p>
      <div class="hero-cta">
        <a href="/contact/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Get a FREE Quote
        </a>
        <a href="tel:+12095550100" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (209) 555-0100
        </a>
      </div>
      <div class="hero-badges">
        <div class="hero-badge"><strong>30+</strong><span>Years Experience</span></div>
        <div class="hero-badge"><strong>1</strong><span>Point of Contact</span></div>
        <div class="hero-badge"><strong>1</strong><span>Simple Invoice</span></div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">What We Do</div>
      <h2 class="section-title">Facility Services Built Around Your Business</h2>
      <p class="section-subtitle">Instead of juggling multiple vendors, you get one point of contact, one invoice, and one team that handles everything — cleaning, maintenance, and repairs.</p>
      <div class="card-grid card-grid-3">
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial Cleaning</h3>
          <p>Janitorial services, office cleaning, and deep cleaning programs tailored to your schedule and space. From daily maintenance to one-time deep cleans.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Office Cleaning</h3>
          <p>Healthcare-grade disinfection for dental offices, medical centers, and clinics. EPA-approved products, compliant protocols, and measured quality assurance.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Building Maintenance</h3>
          <p>Repairs, preventative maintenance, HVAC service, and vendor coordination — all managed under one contract so you don't have to call multiple companies.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Disinfection Services</h3>
          <p>Hospital-grade disinfection for high-traffic areas, medical environments, and post-illness situations. Protect your staff, patients, and customers.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Work Order Software</h3>
          <p>Built-in work order management at no extra cost. Track cleaning visits, submit requests, and view real-time reports across all your locations.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>Measured Success® QA</h3>
          <p>Every cleaning visit is documented and inspected. QR-based feedback, quality reports, and accountability — no more wondering if the job got done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">How It Works</div>
      <h2 class="section-title">Simple. Reliable. Local.</h2>
      <div class="steps">
        <div class="step" data-animate><div class="step-number">1</div><h3>One Point of Contact</h3><p>No more calling five different vendors. One account manager handles everything for your San Joaquin Valley locations.</p></div>
        <div class="step" data-animate><div class="step-number">2</div><h3>One Simple Invoice</h3><p>Cleaning, maintenance, and repairs — all on one bill. No more sorting through multiple invoices every month.</p></div>
        <div class="step" data-animate><div class="step-number">3</div><h3>Integrated Solutions</h3><p>We coordinate cleaning, maintenance, and vendors so everything runs smoothly across every location you manage.</p></div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Industries</div>
      <h2 class="section-title">Serving Businesses Across the Valley</h2>
      <p class="section-subtitle">From medical offices in Manteca to retail spaces in Modesto — we understand the unique needs of San Joaquin Valley businesses.</p>
      <div class="industry-grid">
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏥 Medical & Dental Offices</h3><p>Healthcare-grade cleaning and disinfection for clinics, dental offices, and medical centers throughout Manteca, Modesto, and Stockton.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏢 Commercial Offices</h3><p>Daily janitorial, carpet care, and building maintenance for offices in Tracy, Lodi, and across the Valley.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🛒 Retail Stores</h3><p>Floor care, display cleaning, and high-traffic area maintenance for retail businesses in Stanislaus and San Joaquin counties.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏦 Financial Institutions</h3><p>Discreet, professional cleaning for banks and credit unions. Security-conscious teams that respect your operations.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🍽️ Restaurants</h3><p>Kitchen deep cleaning, grease management, and dining area sanitation for restaurants across the Valley.</p></div></div>
        <div class="industry-card" data-animate><div class="industry-card-body"><h3>🏋️ Fitness Centers</h3><p>Equipment disinfection, locker room cleaning, and odor control for gyms and fitness facilities.</p></div></div>
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">Local Service</div>
      <h2 class="section-title">Serving San Joaquin & Stanislaus Counties</h2>
      <p class="section-subtitle">We're your neighbors. Local teams, local account managers, local accountability.</p>
      <div class="areas-grid">
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Manteca</strong><br/><span>Headquarters area — fast response times</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Modesto</strong><br/><span>Stanislaus County — full service coverage</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Stockton</strong><br/><span>San Joaquin County seat — daily routes</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Tracy</strong><br/><span>Fast-growing community — flexible scheduling</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Lodi</strong><br/><span>Wine country businesses — specialty care</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Turlock</strong><br/><span>Stanislaus County — medical and office focus</span></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Ready for Better Facility Services?</h2>
      <p>Get a free quote for your San Joaquin Valley or Stanislaus County business. One call, one partner, one invoice.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Get a FREE Quote</a>
        <a href="tel:+12095550100" class="btn-secondary">Call (209) 555-0100</a>
      </div>
    </div>
  </section>

</Layout>