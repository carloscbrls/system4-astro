---
import Layout from '../layouts/Layout.astro';

const title = 'Commercial Cleaning & Facility Services | System4 of San Joaquin Valley';
const description = 'System4 of San Joaquin Valley — GSA-approved commercial cleaning, janitorial, and facility services for medical, dental, office, and multi-site organizations across Stockton, Modesto, Tracy, Manteca, Lodi, and Turlock. One contact. One invoice. One solution.';
const canonicalUrl = 'https://system4sjv.com/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero -->
  <section class="hero" data-animate>
    <img src="/images/hero-office.jpg" alt="Clean modern office lobby" class="hero-bg" loading="eager" />
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-tag">GSA Contract Holder — 47QSMS24D0089</div>
        <h1>Commercial Cleaning &<br/>Facility Services in the <em>San Joaquin Valley</em></h1>
        <p class="hero-tagline">Pure Clean. Proven Maintenance. One Partner.</p>
        <p class="hero-sub">System4 delivers customized cleaning programs for medical offices, dental practices, professional offices, and multi-site organizations — with the resources of a national company and the attention of a local partner.</p>
        <div class="hero-cta">
          <a href="/contact/" class="btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Get a Free Quote
          </a>
          <a href="tel:+12092292066" class="btn-secondary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (209) 229-2066
          </a>
        </div>
        <div class="hero-badges">
          <div class="hero-badge"><strong>One</strong><span>Contact</span></div>
          <div class="hero-badge"><strong>One</strong><span>Invoice</span></div>
          <div class="hero-badge"><strong>One</strong><span>Solution</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote form — separate section for mobile, overlaps hero on desktop -->
  <section class="hero-form-section" data-animate>
    <div class="container">
      <div class="hero-form-wrap">
        <form class="hero-form" name="contact" method="POST" data-netlify="true" action="/contact/thanks/">
          <h2 class="hero-form-title">Get Your Free Quote</h2>
          <p style="color:var(--gray-500);font-size:.88rem;margin-bottom:1.25rem;">Tell us about your facility. We'll respond within 24 hours.</p>
          <label for="quote-name" class="sr-only">Full Name</label>
          <input type="text" id="quote-name" name="name" placeholder="Full Name *" required aria-required="true" autocomplete="name" />
          <label for="quote-email" class="sr-only">Email Address</label>
          <input type="email" id="quote-email" name="email" placeholder="Email Address *" required aria-required="true" autocomplete="email" />
          <label for="quote-phone" class="sr-only">Phone Number</label>
          <input type="tel" id="quote-phone" name="phone" placeholder="Phone Number" autocomplete="tel" />
          <label for="quote-service" class="sr-only">Select a Service</label>
          <select id="quote-service" name="service" aria-label="Select a service type" autocomplete="off">
            <option value="" disabled selected>Select a Service</option>
            <option value="commercial-cleaning">Commercial & Office Cleaning</option>
            <option value="medical-dental">Medical & Dental Office Cleaning</option>
            <option value="janitorial">Janitorial Services</option>
            <option value="day-porter">Day Porter Services</option>
            <option value="floor-care">Floor Care & Carpet</option>
            <option value="disinfection">High-Touch Disinfection</option>
            <option value="other">Other / Custom</option>
          </select>
          <label for="quote-city" class="sr-only">City</label>
          <input type="text" id="quote-city" name="city" placeholder="City (e.g. Stockton, Modesto)" />
          <button type="submit" class="btn-primary btn-block">Get My Free Quote</button>
          <p class="hero-form-disclaimer">By submitting, you agree to be contacted about your request.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Trust Stats -->
  <section class="stats-bar" data-animate>
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-number">20+</span>
        <span class="stat-label">Years of Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">67+</span>
        <span class="stat-label">System4 Locations Nationwide</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">100K+</span>
        <span class="stat-label">Clients Served</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">500K+</span>
        <span class="stat-label">Jobs Completed</span>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Our Services</div>
      <h2 class="section-title">Commercial Cleaning Services</h2>
      <p class="section-subtitle">Whether you manage a single office or a multi-site portfolio, we build a customized program that supports consistent results, reliable communication, and flexible adjustments as needs change.</p>
      <div class="card-grid card-grid-3">
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial & Office Cleaning</h3>
          <p>Routine and nightly cleaning programs for professional offices and multi-tenant buildings.</p>
        </a>
        <a href="/industries/medical-dental/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Office Cleaning</h3>
          <p>Healthcare-focused cleaning supporting infection-control best practices and consistency.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Janitorial Services</h3>
          <p>Reliable service including restrooms, trash removal, dusting, break rooms, and floor care.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Day Porter Services</h3>
          <p>Daytime upkeep for lobbies, restrooms, and high-traffic areas to keep spaces client-ready.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Floor Care & Carpet Maintenance</h3>
          <p>Strip & wax, scrub & recoat, carpet care, and ongoing floor maintenance programs.</p>
        </a>
        <a href="/services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>High-Touch Disinfection</h3>
          <p>High-touch point focus for doors, switches, restrooms, break rooms, and common areas.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why System4 -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">Why System4</div>
      <h2 class="section-title">Why Facility Managers Choose System4</h2>
      <p class="section-subtitle">The resources of a national company. The attention of a local partner. No long-term contracts.</p>
      <div class="steps">
        <div class="step" data-animate>
          <div class="step-number">1</div>
          <h3>Dedicated Territory Manager</h3>
          <p>One person owns your account — from walkthrough to quality inspections. No call centers, no runaround. Your territory manager knows your building, your schedule, and your standards.</p>
        </div>
        <div class="step" data-animate>
          <div class="step-number">2</div>
          <h3>Quality Assurance Inspections</h3>
          <p>Regular on-site inspections catch issues before you do. We document everything, adjust immediately, and keep your facility at the standard you expect.</p>
        </div>
        <div class="step" data-animate>
          <div class="step-number">3</div>
          <h3>Customized & Flexible Programs</h3>
          <p>No long-term contracts. We tailor service frequency and timing to fit your operations — and adjust as your needs change. Cancel anytime if we don't meet your standards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label">Industries</div>
      <h2 class="section-title">Industries We Serve</h2>
      <p class="section-subtitle">From medical offices requiring infection-control protocols to auto dealerships needing showroom-ready presentation — we customize for your industry.</p>
      <div class="industry-grid">
        <a href="/industries/medical-dental/" class="industry-card" data-animate>
          <img src="/images/industry-medical.jpg" alt="Medical office cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Medical & Dental Offices</h3>
            <p>Cleaning programs designed for busy healthcare environments with infection-control protocols.</p>
          </div>
        </a>
        <a href="/industries/professional-offices/" class="industry-card" data-animate>
          <img src="/images/industry-office.jpg" alt="Professional office cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Professional Offices</h3>
            <p>Keep client-facing spaces spotless and ready for meetings — lobbies, conference rooms, and break rooms.</p>
          </div>
        </a>
        <a href="/industries/education/" class="industry-card" data-animate>
          <img src="/images/industry-education.jpg" alt="Education facility cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Education & Schools</h3>
            <p>Support for classrooms, offices, and common areas on your schedule — minimizing disruption.</p>
          </div>
        </a>
        <a href="/industries/dealerships/" class="industry-card" data-animate>
          <img src="/images/industry-dealership.jpg" alt="Dealership showroom cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Dealerships & Showrooms</h3>
            <p>Presentation-focused cleaning that helps your showroom make the right first impression.</p>
          </div>
        </a>
        <a href="/industries/banks/" class="industry-card" data-animate>
          <img src="/images/industry-bank.jpg" alt="Bank branch cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Banks & Financial</h3>
            <p>Detail-oriented cleaning for high-traffic, customer-facing areas where appearance is everything.</p>
          </div>
        </a>
        <a href="/industries/warehouses/" class="industry-card" data-animate>
          <img src="/images/industry-warehouse.jpg" alt="Warehouse cleaning" loading="lazy" />
          <div class="industry-card-body">
            <h3>Warehouses & Light Industrial</h3>
            <p>Practical cleaning solutions for back-of-house environments — floors, restrooms, and common areas.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">Local Service</div>
      <h2 class="section-title">Serving the San Joaquin Valley</h2>
      <p class="section-subtitle">Daily routes across San Joaquin County and Stanislaus County. A local team means fast response times and real accountability.</p>
      <div class="areas-grid">
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Stockton</strong><br/><span>San Joaquin County seat — daily routes</span></div>
        </div>
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Modesto</strong><br/><span>Stanislaus County — full service coverage</span></div>
        </div>
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Tracy</strong><br/><span>Fast-growing community — flexible scheduling</span></div>
        </div>
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Manteca</strong><br/><span>Central location — fast response times</span></div>
        </div>
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Lodi</strong><br/><span>Wine country businesses — specialty care</span></div>
        </div>
        <div class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Turlock</strong><br/><span>Stanislaus County — medical and office focus</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- GSA / Trust Section -->
  <section class="section trust-section" data-animate>
    <div class="container trust-inner">
      <div class="trust-badge">
        <div class="gsa-shield">
          <svg width="48" height="48" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <div>
          <h3>GSA Contract Holder</h3>
          <p>System4 is a federally approved GSA vendor (Contract #47QSMS24D0089). We meet the rigorous standards required for government facilities — the same quality we bring to every client.</p>
        </div>
      </div>
      <div class="trust-items">
        <div class="trust-item">
          <svg width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>No long-term contracts — cancel anytime</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Dedicated territory manager — one point of contact</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Regular quality inspections included</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>National resources, local accountability</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <img src="/images/cta-meeting.jpg" alt="Business meeting about facility services" class="cta-bg" loading="lazy" />
    <div class="container">
      <h2>Ready for a Cleaner Facility?</h2>
      <p>Get a free, no-obligation walkthrough and custom cleaning program. We'll assess your space, identify your needs, and deliver a proposal — typically within 24 hours.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary btn-lg">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary btn-lg">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-ghost">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Screen reader only */
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

  /* Hero with form layout */
  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }
  /* Form section — overlaps hero on desktop */
  .hero-form-section {
    position: relative;
    z-index: 2;
    margin-top: -3rem;
    padding-bottom: 2rem;
  }
  .hero-form-wrap {
    max-width: 420px;
    margin: 0 auto;
  }
  .hero-tag {
    display: inline-block;
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,.25);
    color: var(--blue);
    font-size: .8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }
  .hero-tagline {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--green-500);
    margin-bottom: .5rem;
    letter-spacing: .02em;
    text-shadow: 0 1px 3px rgba(0,0,0,.3);
  }
  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 600px;
    opacity: .92;
  }
  .hero-form-wrap {
    position: relative;
  }
  .hero-form {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: 0 12px 40px rgba(0,0,0,.12), 0 0 0 1px rgba(255,255,255,.1);
    display: flex;
    flex-direction: column;
    gap: .75rem;
    position: relative;
    overflow: hidden;
  }
  .hero-form::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--magenta), var(--blue));
  }
  .hero-form h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 0;
  }
  .form-group{margin-bottom:0}
  .hero-form input,
  .hero-form select {
    padding: .75rem 1rem;
    border: 1.5px solid var(--gray-300);
    border-radius: var(--radius-sm);
    font-size: .92rem;
    font-family: var(--font-body);
    color: var(--gray-900);
    background: var(--gray-50);
    transition: all .3s cubic-bezier(.25,.46,.45,.94);
  }
  .hero-form input:focus,
  .hero-form select:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(16,108,176,.12);
    background: var(--white);
  }
  .hero-form input::placeholder {
    color: var(--gray-500);
  }
  .btn-block {
    width: 100%;
    justify-content: center;
  }
  .btn-lg {
    padding: 1rem 2.25rem;
    font-size: 1.05rem;
  }
  .hero-form-disclaimer {
    font-size: .75rem;
    color: var(--gray-500);
    text-align: center;
    margin-bottom: 0;
  }

  /* Stats bar */
  .stats-bar {
    background: var(--white);
    border-bottom: 1px solid var(--gray-100);
    padding: 2rem 1.5rem;
  }
  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }
  .stat {
    text-align: center;
    padding: 0 2.5rem;
  }
  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--blue);
    font-weight: 700;
    line-height: 1.1;
  }
  .stat-label {
    display: block;
    font-size: .85rem;
    color: var(--gray-500);
    margin-top: .25rem;
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--gray-300);
  }

  /* Cards as links */
  .card {
    text-decoration: none;
    display: block;
    cursor: pointer;
  }
  .card h3,
  .card p {
    color: inherit;
  }

  /* Industry cards as links */
  .industry-card {
    text-decoration: none;
    display: block;
    cursor: pointer;
  }
  .industry-card h3,
  .industry-card p {
    color: inherit;
  }
  .industry-emoji {
    font-size: 2rem;
    margin-bottom: .5rem;
  }

  /* Trust section */
  .trust-section {
    background: linear-gradient(135deg, #f0f7ff, #e8f4f8);
    position: relative;
    overflow: hidden;
  }
  .trust-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(16,108,176,.06), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .trust-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .gsa-shield {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--blue), var(--blue-dark));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: .75rem;
    box-shadow: 0 4px 12px rgba(16,108,176,.25);
    transition: all .4s cubic-bezier(.25,.46,.45,.94);
  }
  .trust-badge:hover .gsa-shield {
