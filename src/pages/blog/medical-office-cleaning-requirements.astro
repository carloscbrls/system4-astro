const pubDate = '2026-07-10';
const author = 'System4 San Joaquin Valley';
const slug = 'medical-office-cleaning-requirements';
---

<Layout title={title} description={description}>
  <article class="blog-post" itemscope itemtype="https://schema.org/Article">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": pubDate,
      "author": { "@type": "Organization", "name": "System4 San Joaquin Valley" },
