---
import Layout from '../layouts/Layout.astro';

const title = 'Accessibility Statement | System4 of San Joaquin Valley';
const description = 'Accessibility statement for System4 of San Joaquin Valley. We are committed to ensuring digital accessibility for all users.';
const canonicalUrl = 'https://system4sjv.com/accessibility/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h1 class="section-title">Accessibility Statement</h1>
      <p style="color:var(--gray-500);font-size:.85rem;">Last updated: July 2026</p>

      <p style="color:var(--gray-500);line-height:1.8;margin-top:1.5rem;">System4 of San Joaquin Valley is committed to ensuring digital accessibility for people with disabilities. We continually improve the user experience for everyone and apply relevant accessibility standards.</p>

      <h2 style="font-family:var(--font-display);font-size:1.3rem;margin-top:2rem;margin-bottom:.75rem;color:var(--gray-900);">Conformance Status</h2>
      <p style="color:var(--gray-500);line-height:1.8;">This website aims to conform to the Web Content Accessibility Guidelines (WCAG) 2.2 Level AA. We are actively working to identify and address accessibility barriers across the site.</p>

      <h2 style="font-family:var(--font-display);font-size:1.3rem;margin-top:2rem;margin-bottom:.75rem;color:var(--gray-900);">Measures We Take</h2>
      <ul style="color:var(--gray-500);line-height:2;">
        <li>Ensure sufficient color contrast ratios</li>
        <li>Provide meaningful alternative text for images</li>
        <li>Maintain keyboard-navigable interface elements</li>
        <li>Use semantic HTML structure for screen reader compatibility</li>
        <li>Design responsive layouts that adapt to different screen sizes</li>
      </ul>

      <h2 style="font-family:var(--font-display);font-size:1.3rem;margin-top:2rem;margin-bottom:.75rem;color:var(--gray-900);">Feedback</h2>
      <p style="color:var(--gray-500);line-height:1.8;">If you encounter accessibility barriers on our website, please let us know. We welcome your feedback and will make every effort to provide accessible alternatives.</p>
      <p style="color:var(--gray-500);line-height:1.8;margin-top:.5rem;">Contact: <a href="mailto:jcastillo@system4.com" class="content-link">jcastillo@system4.com</a> | <a href="tel:+12092292066" class="content-link">(209) 229-2066</a></p>
    </div>
  </section>

</Layout>