---
import Layout from '../layouts/Layout.astro';

const title = 'Industries We Serve | System4 of San Joaquin Valley';
const description = 'System4 serves medical offices, dental clinics, professional offices, schools, dealerships, banks, and warehouses across San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Industries", "item": "https://system4sjv.com/industries/"}
  ]
};

const industries = [
  {
    href: '/industries/medical-dental/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    title: 'Medical & Dental Offices',
    desc: 'Cleaning programs designed for busy healthcare environments. Infection-control best practices, high-touch point emphasis, and customized scope for your compliance needs.'
  },
  {
    href: '/industries/professional-offices/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
    title: 'Professional Offices',
    desc: 'Keep client-facing spaces spotless and ready for meetings. Nightly and daytime programs for professional offices and multi-tenant buildings.'
  },
  {
    href: '/industries/education/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 3 3 6 3s6-1 6-3v-5"/></svg>',
    title: 'Education & Schools',
    desc: 'Support for classrooms, offices, and common areas on your schedule. Disinfection programs that keep students and staff safe.'
  },
  {
    href: '/industries/dealerships/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m7 0H9M5 11V9a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2M5 11h14v5a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-5zM7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/></svg>',
    title: 'Dealerships & Showrooms',
    desc: 'Presentation-focused cleaning to help spaces shine. Showrooms, service areas, and customer lounges kept to showroom standards.'
  },
  {
    href: '/industries/banks/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v7M12 14v7M16 14v7"/></svg>',
    title: 'Banks & Financial',
    desc: 'Detail-oriented cleaning for high-traffic, customer-facing areas. Security-conscious teams that respect your operations.'
  },
  {
    href: '/industries/warehouses/',
    icon: '<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 21v-4h6v4"/><path d="M9 10h.01M15 10h.01"/></svg>',
    title: 'Warehouses & Light Industrial',
    desc: 'Practical cleaning solutions for back-of-house environments. Floor care, restrooms, break rooms, and common areas.'
  }
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={breadcrumbSchema}>

  <!-- Hero -->
  <section class="hero hero-compact" data-animate>
    <img src="/images/industries-hero.jpg" alt="Commercial cleaning serving diverse industries" class="hero-bg" loading="eager" />
    <div class="container" style="max-width:960px;text-align:center;">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Industries</div>
      <h1>Industries <em>We Serve</em></h1>
      <p style="max-width:600px;margin-left:auto;margin-right:auto;">Trusted by facility managers who need consistent service, responsive communication, and accountability.</p>
    </div>
  </section>

  <!-- Industry Cards -->
  <section class="section" data-animate>
    <div class="container" style="max-width:1080px;">
      <div class="section-label" style="text-align:center;">Specialized Expertise</div>
      <h2 class="section-title" style="text-align:center;">Tailored for Your Industry</h2>
      <p class="section-subtitle" style="text-align:center;margin-left:auto;margin-right:auto;">Every facility type has unique requirements. We build programs around yours.</p>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        {industries.map((ind) => (
          <a href={ind.href} class="card" data-animate style="text-decoration:none;color:inherit;">
            <div class="card-icon" set:html={ind.icon} />
            <h3>{ind.title}</h3>
            <p>{ind.desc}</p>
            <span class="card-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why System4 -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:960px;text-align:center;">
      <div class="section-label" style="text-align:center;">Why System4</div>
      <h2 class="section-title" style="text-align:center;">One Partner. One Invoice. One Standard.</h2>
      <p class="section-subtitle" style="text-align:center;margin-left:auto;margin-right:auto;">We eliminate the hassle of managing multiple vendors, inconsistent quality, and surprise costs.</p>
      <div class="trust-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2.5rem;text-align:left;">
        <div>
          <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;color:var(--navy);margin-bottom:.5rem;">Responsive Communication</div>
          <p style="color:var(--gray-700);font-size:.9rem;line-height:1.6;">Dedicated account managers who answer calls and respond within hours — not days.</p>
        </div>
        <div>
          <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;color:var(--navy);margin-bottom:.5rem;">Consistent Quality</div>
          <p style="color:var(--gray-700);font-size:.9rem;line-height:1.6;">Inspection programs, checklists, and feedback loops that keep your facility at standard — every visit.</p>
        </div>
        <div>
          <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;color:var(--navy);margin-bottom:.5rem;">Custom Programs</div>
          <p style="color:var(--gray-700);font-size:.9rem;line-height:1.6;">Scope built around your facility type, traffic patterns, and compliance requirements — not a cookie-cutter checklist.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:linear-gradient(135deg,#d4376e 0%,#e8447a 40%,#c42d63 100%);padding:3rem 1.5rem;text-align:center;color:white;position:relative;overflow:hidden">
    <div style="max-width:720px;margin:0 auto;position:relative;z-index:1">
      <h2 style="font-size:1.75rem;font-weight:700;color:white;-webkit-text-fill-color:white;margin:0 0 .75rem;padding:0;text-align:center;line-height:1.2">Need Service for Your Industry?</h2>
      <p style="font-size:1rem;line-height:1.6;color:white;-webkit-text-fill-color:white;margin:0 auto 1.5rem;max-width:520px;text-align:center;opacity:.92">We customize programs for every facility type. Tell us what you manage and we'll build the right program.</p>
      <div style="display:flex;flex-direction:column;align-items:center;gap:.6rem">
        <a href="/contact/" style="display:block;width:100%;max-width:300px;padding:.85rem 2rem;background:white;color:#d4376e;-webkit-text-fill-color:#d4376e;border-radius:12px;font-weight:700;font-size:1rem;text-decoration:none;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,.15)">Get a Free Quote</a>
        <a href="tel:+12092292066" style="display:block;width:100%;max-width:300px;padding:.85rem 2rem;background:rgba(255,255,255,.12);color:white;-webkit-text-fill-color:white;border:2px solid white;border-radius:12px;font-weight:700;font-size:1rem;text-decoration:none;text-align:center;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
    text-align: left;
  }
  @media (max-width: 768px) {
    .trust-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>