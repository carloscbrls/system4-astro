---
import Layout from '../layouts/Layout.astro';

const title = 'Industries We Serve | System4 of San Joaquin Valley';
const description = 'System4 serves medical offices, dental clinics, professional offices, schools, dealerships, banks, and warehouses across San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <section class="hero hero-compact" data-animate>
    <img src="/images/industries-hero.jpg" alt="Commercial cleaning serving diverse industries" class="hero-bg" loading="eager" />
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Industries</div>
      <h1>Industries <em>We Serve</em></h1>
      <p>Trusted by facility managers who need consistent service, responsive communication, and accountability.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="industry-grid">
        <a href="/industries/medical-dental/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>Medical & Dental Offices</h3>
            <p>Cleaning programs designed for busy healthcare environments. Infection-control best practices, high-touch point emphasis, and customized scope for your compliance needs.</p>
            <span class="card-link">Learn more →</span>
          </div>
        </a>
        <a href="/industries/professional-offices/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>🏢 Professional Offices</h3>
            <p>Keep client-facing spaces spotless and ready for meetings. Nightly and daytime programs for professional offices and multi-tenant buildings.</p>
            <span style="color:var(--blue);font-size:.85rem;font-weight:600;">Learn more →</span>
          </div>
        </a>
        <a href="/industries/education/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>🎓 Education & Schools</h3>
            <p>Support for classrooms, offices, and common areas on your schedule. Disinfection programs that keep students and staff safe.</p>
            <span style="color:var(--blue);font-size:.85rem;font-weight:600;">Learn more →</span>
          </div>
        </a>
        <a href="/industries/dealerships/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>🚗 Dealerships & Showrooms</h3>
            <p>Presentation-focused cleaning to help spaces shine. Showrooms, service areas, and customer lounges kept to showroom standards.</p>
            <span style="color:var(--blue);font-size:.85rem;font-weight:600;">Learn more →</span>
          </div>
        </a>
        <a href="/industries/banks/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>🏦 Banks & Financial</h3>
            <p>Detail-oriented cleaning for high-traffic, customer-facing areas. Security-conscious teams that respect your operations.</p>
            <span style="color:var(--blue);font-size:.85rem;font-weight:600;">Learn more →</span>
          </div>
        </a>
        <a href="/industries/warehouses/" class="industry-card" data-animate style="text-decoration:none;">
          <div class="industry-card-body">
            <h3>🏭 Warehouses & Light Industrial</h3>
            <p>Practical cleaning solutions for back-of-house environments. Floor care, restrooms, break rooms, and common areas.</p>
            <span style="color:var(--blue);font-size:.85rem;font-weight:600;">Learn more →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Need Service for Your Industry?</h2>
      <p>We customize programs for every facility type. Tell us what you manage and we'll build the right program.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>