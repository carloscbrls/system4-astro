---
import Layout from '../../layouts/Layout.astro';

const city = 'Lodi';
const county = 'San Joaquin County';
const slug = 'lodi';
const title = 'Commercial Cleaning in Lodi, CA | System4 of San Joaquin Valley';
const description = 'Professional commercial cleaning, janitorial, and day porter services in Lodi, CA. DGS certified. No long-term contracts. Dedicated territory manager for your facility.';
const canonicalUrl = `https://system4sjv.com/cities/${slug}/`;
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "System4 San Joaquin Valley",
    "description": description,
    "url": canonicalUrl,
    "telephone": "+1-209-229-2066",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": city,
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": city
    },
    "serviceType": ["Commercial Cleaning", "Janitorial Services", "Day Porter Services", "Floor Care", "Disinfection Services"]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/" },
      { "@type": "ListItem", "position": 2, "name": city, "item": canonicalUrl }
    ]
  })} />

  <!-- Hero -->
  <section class="hero hero-compact" data-animate style="position:relative;overflow:hidden;">
    <img src="/images/city-lodi.jpg" alt="Professional commercial cleaning services" class="hero-bg" loading="eager" />
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-tag">Serving {city}</div>
        <h1>Commercial Cleaning Services in {city}</h1>
        <p class="hero-tagline">One Contact. One Invoice. One Solution.</p>
        <p class="hero-sub">System4 provides customized cleaning programs for offices, medical facilities, and commercial buildings throughout {city} and {county}. No long-term contracts — just consistent results.</p>
        <div class="hero-cta">
          <a href="/contact/" class="btn-primary btn-lg">Get a Free Quote</a>
          <a href="tel:+12092292066" class="btn-secondary btn-lg">Call (209) 229-2066</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar" data-animate>
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-number">20+</span>
        <span class="stat-label">Years of Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">67+</span>
        <span class="stat-label">System4 Locations Nationwide</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">100K+</span>
        <span class="stat-label">Clients Served</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">500K+</span>
        <span class="stat-label">Jobs Completed</span>
      </div>
    </div>
  </section>

  <!-- Services We Offer in Lodi -->
  <section class="section" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="section-label" style="text-align:center;">Services in {city}</div>
      <h2 class="section-title" style="text-align:center;">Cleaning Services Available in {city}</h2>
      <p class="section-subtitle">From medical offices near Lodi Memorial to professional buildings downtown — we tailor every program to your facility's specific needs.</p>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <a href="/commercial-cleaning/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial & Office Cleaning</h3>
          <p>Routine and nightly cleaning for Lodi's professional offices, winery tasting rooms, and multi-tenant buildings.</p>
        </a>
        <a href="/janitorial-services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Janitorial Services</h3>
          <p>Reliable daily and weekly janitorial support for Lodi businesses — restrooms, break rooms, trash, and common areas.</p>
        </a>
        <a href="/day-porter-services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Day Porter Services</h3>
          <p>Daytime upkeep for Lodi lobbies, restrooms, and high-traffic areas — keep your facility client-ready throughout the day.</p>
        </a>
        <a href="/medical-office-cleaning/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Office Cleaning</h3>
          <p>Healthcare-focused cleaning for Lodi's medical and dental practices with infection-control protocols.</p>
        </a>
        <a href="/floor-care/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Floor Care & Carpet Maintenance</h3>
          <p>Strip & wax, scrub & recoat, and carpet care programs for Lodi commercial facilities.</p>
        </a>
        <a href="/disinfection-services/" class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>High-Touch Disinfection</h3>
          <p>Targeted disinfection for Lodi facilities — doors, switches, restrooms, break rooms, and common areas.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Lodi Businesses Choose System4 -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="section-label" style="text-align:center;">Why {city}</div>
      <h2 class="section-title" style="text-align:center;">Why {city} Businesses Choose System4</h2>
      <p class="section-subtitle">Known for its world-class wine country and historic downtown, Lodi's businesses demand a higher standard of presentation. Here's why local facility managers trust us.</p>
      <div class="steps">
        <div class="step" data-animate>
          <div class="step-number">1</div>
          <h3>Dedicated Territory Manager</h3>
          <p>Your Lodi facility gets one point of contact who knows your building, your schedule, and your standards. No call centers, no runaround — just a real person who owns your account from walkthrough to quality inspections.</p>
        </div>
        <div class="step" data-animate>
          <div class="step-number">2</div>
          <h3>Quality Assurance Inspections</h3>
          <p>Regular on-site inspections catch issues before you do. We document everything, adjust immediately, and keep your Lodi facility at the standard you expect.</p>
        </div>
        <div class="step" data-animate>
          <div class="step-number">3</div>
          <h3>Customized & Flexible Programs</h3>
          <p>No long-term contracts. We tailor service frequency and timing to fit your Lodi operations — and adjust as your needs change. Cancel anytime if we don't meet your standards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries We Serve in Lodi -->
  <section class="section" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="section-label" style="text-align:center;">Industries in {city}</div>
      <h2 class="section-title" style="text-align:center;">Industries We Serve in {city}</h2>
      <p class="section-subtitle">From medical offices to winery tasting rooms — we customize for your industry.</p>
      <div class="industry-grid" style="margin-top:2.5rem;">
        <a href="/industries/medical-dental/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Medical & Dental Offices</h3>
            <p>Infection-control cleaning for Lodi's healthcare facilities, clinics, and dental practices.</p>
          </div>
        </a>
        <a href="/industries/professional-offices/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Professional Offices</h3>
            <p>Keep Lodi's client-facing spaces spotless — lobbies, conference rooms, and break rooms.</p>
          </div>
        </a>
        <a href="/industries/education/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Education & Schools</h3>
            <p>Cleaning support for Lodi's educational facilities on your schedule.</p>
          </div>
        </a>
        <a href="/industries/dealerships/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Dealerships & Showrooms</h3>
            <p>Presentation-focused cleaning for Lodi auto dealerships and showrooms.</p>
          </div>
        </a>
        <a href="/industries/banks/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Banks & Financial</h3>
            <p>Detail-oriented cleaning for Lodi's financial institutions and bank branches.</p>
          </div>
        </a>
        <a href="/industries/warehouses/" class="industry-card" data-animate>
          <div class="industry-card-body">
            <h3>Warehouses & Light Industrial</h3>
            <p>Practical cleaning for Lodi's warehouse and industrial facilities.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Service Area / Nearby Cities -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="section-label" style="text-align:center;">Service Area</div>
      <h2 class="section-title" style="text-align:center;">Also Serving Near {city}</h2>
      <p class="section-subtitle">Daily routes across {county} and surrounding areas. We're local — fast response times and real accountability.</p>
      <div class="areas-grid">
        <a href="/cities/stockton/" class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Stockton</strong><br/><span>San Joaquin County seat — daily routes</span></div>
        </a>
        <a href="/cities/manteca/" class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Manteca</strong><br/><span>Central location — fast response times</span></div>
        </a>
        <a href="/cities/tracy/" class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Tracy</strong><br/><span>Fast-growing community — flexible scheduling</span></div>
        </a>
        <a href="/cities/modesto/" class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Modesto</strong><br/><span>Stanislaus County — full service coverage</span></div>
        </a>
        <a href="/cities/turlock/" class="area-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div><strong>Turlock</strong><br/><span>Stanislaus County — medical and office focus</span></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="section trust-section" data-animate>
    <div class="container trust-inner">
      <div class="trust-badge">
        <div class="dgs-shield">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <div>
          <h3>DGS Certified</h3>
          <p>System4 is a DGS certified business (Cert. ID 2022081). We meet the rigorous standards required for government facilities — the same quality we bring to every {city} client.</p>
        </div>
      </div>
      <div class="trust-items">
        <div class="trust-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>No long-term contracts — cancel anytime</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Dedicated territory manager — one point of contact</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Regular quality inspections included</span>
        </div>
        <div class="trust-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>National resources, local accountability</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Ready for a Cleaner Facility in {city}?</h2>
      <p>Get a free, no-obligation walkthrough and custom cleaning program for your {city} facility. We'll assess your space, identify your needs, and deliver a proposal — typically within 24 hours.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary btn-lg">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary btn-lg">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-ghost">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ===== PREMIUM CITY PAGE STYLES ===== */

  /* Stats Bar — Frosted glass cards with animated feel */
  .stats-bar{background:linear-gradient(135deg,var(--navy) 0%,#0d2847 50%,#132f52 100%)!important;padding:1.5rem 1.5rem!important;position:relative!important;overflow:hidden!important}
  .stats-bar::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 20% 50%,rgba(11,125,218,.15),transparent 60%),radial-gradient(circle at 80% 50%,rgba(212,55,110,.08),transparent 50%);pointer-events:none}
  .stats-inner{display:flex!important;align-items:center!important;justify-content:center!important;gap:2.5rem!important;flex-wrap:wrap!important;position:relative!important;z-index:1!important}
  .stat{display:flex!important;flex-direction:column!important;align-items:center!important;padding:1.5rem 2rem!important;background:rgba(255,255,255,.06)!important;backdrop-filter:blur(12px)!important;-webkit-backdrop-filter:blur(12px)!important;border:1px solid rgba(255,255,255,.1)!important;border-radius:var(--radius-lg)!important;min-width:160px!important;transition:all .4s cubic-bezier(.25,.46,.45,.94)!important}
  .stat:hover{background:rgba(255,255,255,.12)!important;transform:translateY(-4px)!important;box-shadow:0 12px 40px rgba(0,0,0,.25)!important;border-color:rgba(255,255,255,.2)!important}
  .stat-number{font-family:var(--font-display)!important;font-size:2.8rem!important;font-weight:700!important;color:white!important;-webkit-text-fill-color:white!important;background:linear-gradient(135deg,#fff 0%,rgba(255,255,255,.85) 100%)!important;-webkit-background-clip:text!important;background-clip:text!important;letter-spacing:-.02em!important;line-height:1!important;margin-bottom:.35rem!important}
  .stat-label{font-family:var(--font-tight)!important;font-size:.75rem!important;font-weight:600!important;text-transform:uppercase!important;letter-spacing:.1em!important;color:rgba(255,255,255,.65)!important;-webkit-text-fill-color:rgba(255,255,255,.65)!important}
  .stat-divider{width:1px!important;height:48px!important;background:rgba(255,255,255,.15)!important;margin:0 .5rem!important}

  /* Area Cards — Premium with gradient border */
  .area-card{background:var(--white)!important;border:1px solid var(--gray-100)!important;border-radius:var(--radius-lg)!important;padding:1.25rem 1.5rem!important;display:flex!important;align-items:center!important;gap:.75rem!important;transition:all .4s cubic-bezier(.25,.46,.45,.94)!important;position:relative!important;overflow:hidden!important;text-decoration:none!important}
  .area-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:linear-gradient(180deg,var(--blue),var(--magenta))!important;border-radius:0 2px 2px 0!important;opacity:0!important;transition:opacity .3s ease!important}
  .area-card::after{content:'';position:absolute;inset:0;border-radius:inherit;opacity:0!important;background:linear-gradient(135deg,rgba(11,125,218,.03),rgba(212,55,110,.03))!important;transition:opacity .3s ease!important;pointer-events:none!important}
  .area-card:hover{border-color:var(--blue-100)!important;box-shadow:0 8px 32px rgba(0,0,0,.08),0 0 0 1px var(--gray-100)!important;transform:translateY(-2px) translateX(4px)!important}
  .area-card:hover::before{opacity:1!important}
  .area-card:hover::after{opacity:1!important}
  .area-card:hover svg{color:var(--magenta)!important;transform:scale(1.15)!important}
  .area-card strong{color:var(--gray-900)!important;-webkit-text-fill-color:var(--gray-900)!important;font-family:var(--font-tight)!important;font-weight:600!important;font-size:1rem!important;letter-spacing:-.01em!important}
  .area-card span{color:var(--gray-700)!important;font-size:.85rem!important;display:block!important;margin-top:.15rem!important}
  .area-card:hover strong{color:var(--navy)!important;-webkit-text-fill-color:var(--navy)!important}
  .area-card svg{color:var(--green-600)!important;flex-shrink:0!important;transition:all .3s ease!important}

  /* Industry Cards — Premium hover with image overlay */
  .industry-card{background:var(--white)!important;border:1px solid var(--gray-100)!important;border-radius:var(--radius-lg)!important;overflow:hidden!important;transition:all .4s cubic-bezier(.25,.46,.45,.94)!important;position:relative!important;text-decoration:none!important;display:block!important}
  .industry-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--magenta),var(--blue))!important;transform:scaleX(0)!important;transform-origin:left!important;transition:transform .4s cubic-bezier(.25,.46,.45,.94)!important}
  .industry-card:hover{box-shadow:0 16px 48px rgba(0,0,0,.1),0 0 0 1px var(--gray-100)!important;transform:translateY(-6px)!important}
  .industry-card:hover::after{transform:scaleX(1)!important}
  .industry-card h3{color:var(--gray-900)!important;-webkit-text-fill-color:var(--gray-900)!important;font-family:var(--font-tight)!important;font-weight:600!important;font-size:1.15rem!important;letter-spacing:-.005em!important;text-decoration:none!important}
  .industry-card:hover h3{color:var(--magenta)!important;-webkit-text-fill-color:var(--magenta)!important}
  .industry-card p{color:var(--gray-700)!important;font-size:.88rem!important;line-height:1.6!important}
  .industry-card-body{padding:1.5rem!important}

  /* Card — Premium with top accent line */
  .card{background:var(--white)!important;border:1px solid var(--gray-100)!important;border-radius:var(--radius-lg)!important;box-shadow:var(--shadow-sm)!important;padding:2rem!important;position:relative!important;overflow:hidden!important;text-decoration:none!important;display:block!important;transition:transform .3s cubic-bezier(.4,0,.2,1),box-shadow .3s cubic-bezier(.4,0,.2,1)!important}
  .card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--magenta),var(--blue))!important;transform:scaleX(0)!important;transform-origin:left!important;transition:transform .4s cubic-bezier(.25,.46,.45,.94)!important}
  .card:hover{box-shadow:0 12px 40px rgba(0,0,0,.1),0 0 0 1px var(--gray-100)!important;transform:translateY(-4px)!important}
  .card:hover::after{transform:scaleX(1)!important}
  .card h3{color:var(--gray-900)!important;-webkit-text-fill-color:var(--gray-900)!important;font-family:var(--font-tight)!important;font-weight:600!important;letter-spacing:-.005em!important;text-decoration:none!important;margin-bottom:.5rem!important}
  .card:hover h3{color:var(--magenta)!important;-webkit-text-fill-color:var(--magenta)!important}
  .card p{color:var(--gray-700)!important;font-size:.92rem!important;line-height:1.6!important}
  .card-icon{background:linear-gradient(135deg,var(--blue-600),var(--blue-800))!important;box-shadow:0 4px 12px rgba(16,108,176,.25)!important}
  .card:hover .card-icon{transform:scale(1.08)!important;box-shadow:0 6px 18px rgba(16,108,176,.35)!important}

  /* Steps — Premium with green gradient */
  .step-number{background:linear-gradient(135deg,var(--green-600),var(--green-500))!important;box-shadow:0 4px 14px rgba(40,168,102,.3)!important}
  .step:hover .step-number{transform:scale(1.08)!important;box-shadow:0 8px 24px rgba(40,168,102,.4)!important}

  /* Trust Section — Premium glass */
  .trust-section{position:relative!important;overflow:hidden!important;background:var(--gray-50)!important}
