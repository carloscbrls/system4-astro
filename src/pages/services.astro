---
import Layout from '../layouts/Layout.astro';

const title = 'Commercial Cleaning Services | System4 of San Joaquin Valley';
const description = 'System4 of San Joaquin Valley commercial cleaning services: janitorial, office cleaning, medical & dental cleaning, day porter, floor care, and disinfection programs.';
const canonicalUrl = 'https://system4sjv.com/services/';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Services", "item": "https://system4sjv.com/services/"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={breadcrumbSchema}>

  <!-- Hero -->
  <section class="hero hero-compact" data-animate>
    <img src="/images/services-hero.jpg" alt="Commercial cleaning service professionals" class="hero-bg" loading="eager" />
    <div class="container" style="max-width:1080px;text-align:center;">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Our Services</div>
      <h1>Commercial Cleaning<br/>for <em>Facility Managers</em></h1>
      <p style="max-width:600px;margin-left:auto;margin-right:auto;">Customized cleaning programs built around your facility, schedule, and standards. One contact. One invoice. One solution.</p>
      <div class="hero-cta" style="margin-top:1.5rem;">
        <a href="/contact/" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section" data-animate>
    <div class="container" style="max-width:1080px;">
      <div class="section-label" style="text-align:center;">Core Services</div>
      <h2 class="section-title" style="text-align:center;">What We Do Best</h2>
      <p class="section-subtitle" style="text-align:center;margin-left:auto;margin-right:auto;">Each program is built around your facility type, operating hours, and consistency standards.</p>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <a href="/commercial-cleaning/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
          <h3>Commercial & Office Cleaning</h3>
          <p>Routine and nightly cleaning programs for professional offices and multi-tenant buildings.</p>
          <ul class="card-list">
            <li>Trash removal, dusting, break rooms, restrooms</li>
            <li>Vacuuming, mopping, common area detailing</li>
            <li>Custom checklist based on your priorities</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
        <a href="/medical-office-cleaning/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Medical & Dental Cleaning</h3>
          <p>Healthcare-focused cleaning supporting infection-control best practices.</p>
          <ul class="card-list">
            <li>Waiting rooms, operatories, staff areas</li>
            <li>High-touch point emphasis</li>
            <li>Compliance-ready scope</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
        <a href="/janitorial-services/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg></div>
          <h3>Janitorial Services</h3>
          <p>Reliable daily janitorial support designed to keep your facility clean and presentable.</p>
          <ul class="card-list">
            <li>Schedules matching traffic patterns</li>
            <li>Detail-focused restrooms & high-touch</li>
            <li>Inspection feedback loop</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
        <a href="/day-porter-services/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
          <h3>Day Porter Services</h3>
          <p>Daytime upkeep for lobbies, restrooms, and high-traffic areas — keep spaces client-ready.</p>
          <ul class="card-list">
            <li>Continuous cleaning for busy facilities</li>
            <li>Supplies monitoring & restocking</li>
            <li>Spot-cleaning, spills, touch-ups</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
        <a href="/floor-care/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>Floor Care & Carpet</h3>
          <p>Strip & wax, scrub & recoat, carpet care, and ongoing floor maintenance programs.</p>
          <ul class="card-list">
            <li>Protect finishes, extend floor life</li>
            <li>Scheduled programs to reduce downtime</li>
            <li>High-traffic zone targeting</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
        <a href="/disinfection-services/" class="card" data-animate style="text-decoration:none;color:inherit;">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>High-Touch Disinfection</h3>
          <p>High-touch point focus for doors, switches, restrooms, break rooms, and common areas.</p>
          <ul class="card-list">
            <li>Handles, push plates, rails, switches</li>
            <li>Restrooms, break rooms, lobbies</li>
            <li>Ongoing prevention support</li>
          </ul>
          <span class="card-link">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- More Services -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:1080px;text-align:center;">
      <div class="section-label" style="text-align:center;">Additional Services</div>
      <h2 class="section-title" style="text-align:center;">Need Something Outside the Core?</h2>
      <p class="section-subtitle" style="text-align:center;margin-left:auto;margin-right:auto;">We coordinate additional facility support based on your needs.</p>
      <div class="more-services-grid" style="text-align:left;">
        <div>
          <h3 class="more-services-heading">Specialty Cleaning</h3>
          <ul class="more-services-list">
            <li>Post-construction cleanup</li>
            <li>Post-event cleaning</li>
            <li>Stadium / large venue cleaning</li>
            <li>Upholstery cleaning</li>
            <li>Area rug cleaning</li>
          </ul>
        </div>
        <div>
          <h3 class="more-services-heading">Floor & Surface Programs</h3>
          <ul class="more-services-list">
            <li>Scrub & recoat</li>
            <li>Spray buff / burnishing</li>
            <li>Machine scrub hard floors</li>
            <li>Glass & mirror cleaning</li>
            <li>Power / pressure washing</li>
          </ul>
        </div>
        <div>
          <h3 class="more-services-heading">Facility Support</h3>
          <ul class="more-services-list">
            <li>Property maintenance coordination</li>
            <li>Lighting maintenance coordination</li>
            <li>Parking maintenance coordination</li>
            <li>Window cleaning service coordination</li>
            <li>Landscaping coordination</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" data-animate>
    <div class="container" style="max-width:720px;">
      <div class="section-label" style="text-align:center;">FAQ</div>
      <h2 class="section-title" style="text-align:center;">Common Questions</h2>
      <div class="faq-list" style="margin-top:2rem;">
        <details class="faq-item">
          <summary class="faq-question">Do you offer nightly and daytime cleaning?</summary>
          <p class="faq-answer">Yes. We can build a program around your operating hours, including nightly janitorial and daytime porter support.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Can you support multiple locations?</summary>
          <p class="faq-answer">Yes. We coordinate service across multi-site organizations and streamline communication and billing where possible.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">How do you ensure quality?</summary>
          <p class="faq-answer">We use checklists, routine inspections, and a communication process to keep service consistent and make adjustments quickly.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <div class="container" style="max-width:720px;text-align:center;">
      <h2>Not Seeing What You Need?</h2>
      <p>Tell us your service request and we'll confirm availability. For faster quotes, include city, approximate square footage, and service frequency.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-ghost">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Condensed, centered, premium layout */
  .card-grid-3 {
    max-width: 1080px;
    margin-left: auto;
    margin-right: auto;
    gap: 1.75rem;
  }
  .card {
    position: relative;
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    transition: all .4s cubic-bezier(.25,.46,.45,.94);
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    text-decoration: none;
    color: inherit;
  }
  .card-list {
    color: var(--gray-700); -webkit-text-fill-color: var(--gray-700);
    font-size: .85rem;
    line-height: 1.8;
    margin-top: .75rem;
    padding-left: 1rem;
  }
  .card-link {
    display: inline-block;
    margin-top: .75rem;
    color: var(--blue-600);
    font-size: .9rem;
    font-weight: 600;
    transition: all .3s cubic-bezier(.25,.46,.45,.94);
  }
  .card:hover .card-link {
    color: var(--magenta);
    transform: translateX(4px);
  }
  .more-services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2.5rem;
    margin-top: 2.5rem;
  }
  .more-services-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: .75rem;
    color: var(--gray-900);
  }
  .more-services-list {
    color: var(--gray-700); -webkit-text-fill-color: var(--gray-700);
    font-size: .92rem;
    line-height: 2;
  }
  .faq-item {
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    margin-bottom: 1rem;
    background: white;
  }
  .faq-question {
    font-weight: 600;
    cursor: pointer;
    color: var(--gray-900);
    font-size: 1rem;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .faq-question::-webkit-details-marker {
    display: none;
  }
  .faq-question::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--blue);
    transition: transform .2s ease;
  }
  .faq-item[open] .faq-question::after {
    content: '−';
  }
  .faq-answer {
    color: var(--gray-700); -webkit-text-fill-color: var(--gray-700);
    margin-top: .75rem;
    line-height: 1.7;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .more-services-grid {
      grid-template-columns: 1fr;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
    .cta-buttons a {
      text-align: center;
      justify-content: center;
      max-width: 340px;
    }
  }
</style>