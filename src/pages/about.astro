---
import Layout from '../layouts/Layout.astro';

const title = 'About System4 of San Joaquin Valley | Commercial Cleaning & Facility Services';
const description = 'System4 of San Joaquin Valley — locally owned and operated with national network backing. Customized commercial cleaning and facility services for the Central Valley.';
const canonicalUrl = 'https://system4sjv.com/about/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero -->
  <section class="hero hero-compact" data-animate style="position:relative;overflow:hidden">
    <img src="/images/about-team.jpg" alt="Professional cleaning team at work" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.15;pointer-events:none;" loading="eager" />
    <div class="container" style="position:relative;z-index:1;">
      <h1>About <em>System4</em><br/>of San Joaquin Valley</h1>
      <p>Locally owned and operated with the capabilities and resources of a national company. Whether you need basic services, multiple services, or specialized programs — we exceed expectations.</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Locally Owned & Operated,<br/>Nationally Backed</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;margin-top:1.5rem;">System4 of San Joaquin Valley offers customers the combination of the capabilities and resources of a national company, and the attentiveness and flexibility of local ownership. Whether customers need basic services, multiple services, or specialized services, equipment, and/or chemicals, System4 has the experience, capabilities, and resources to exceed your expectations.</p>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;margin-top:1rem;">Whether you are a single location looking for a customized program or a small chain of locations that wants consistent services for all locations, or a national brand that wants uniformity of service and centralized administration, we can handle your needs. If you are a facility coordinator or manager, we make your life easier by sourcing and overseeing qualified service providers to meet your needs.</p>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;margin-top:1rem;">And if your needs change or the service provider is not meeting your requirements, it is our time to shine — we will find you another qualified service provider. System4 is a <strong>GSA Contract Holder</strong> (Contract #47QSMS24D0089), meeting the rigorous standards required for government facilities.</p>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:900px;">
      <div class="mission-grid">
        <div>
          <div class="section-label">Our Mission</div>
          <h2 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:1rem;color:var(--gray-900);">To Be the #1 Option for Facility Service Management</h2>
          <p style="color:var(--gray-500);font-size:.95rem;line-height:1.7;">By delivering unique solutions and solving problems for our clients. We enable our clients to spend more time on their core business while we drive down their costs. We accomplish this by ensuring all team members understand that creating positive results and client experiences is the core of what we do. We focus on building a service provider partner network that delivers exceptional service backed by transparency and accountability from a local System4 office.</p>
        </div>
        <div>
          <div class="section-label">Our Vision</div>
          <h2 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:1rem;color:var(--gray-900);">Do the Right Things for the Right Reasons</h2>
          <p style="color:var(--gray-500);font-size:.95rem;line-height:1.7;">When we make decisions and take actions for the right reasons, we deliver uncompromising value to our clients and partners. There's no point in being able to do it all unless we're also making people happy while doing it. Through our customer-first approach, we perform not only efficiently, but consistently, and act as a reliable resource for the businesses we serve.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="section" data-animate>
    <div class="container">
      <div class="section-label" style="text-align:center;">What Makes Us Different</div>
      <h2 class="section-title" style="text-align:center;">A Simple, Accountable Experience</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <h3>One Point of Contact</h3>
          <p>No more calling five different vendors. Your dedicated account manager handles everything.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
          <h3>One Invoice</h3>
          <p>Cleaning, maintenance, and repairs — all on one bill. Simple, streamlined, predictable.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>Measured Success® QA</h3>
          <p>Routine inspections, documented visits, and a feedback loop that keeps quality consistent.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate style="position:relative;overflow:hidden;">
    <img src="/images/cta-meeting.jpg" alt="Business meeting about facility services" class="cta-bg" loading="lazy" />
    <div class="container" style="position:relative;z-index:1;">
      <h2>Ready for Better Facility Services?</h2>
      <p>Get a free walkthrough and customized proposal for your San Joaquin Valley business.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-secondary">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .cta-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .15; pointer-events: none; }
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  @media (max-width: 768px) {
    .mission-grid {
      grid-template-columns: 1fr;
    }
  }
</style>