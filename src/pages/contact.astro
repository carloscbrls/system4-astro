---
import Layout from '../layouts/Layout.astro';

const title = 'Contact System4 of San Joaquin Valley | Request a Walkthrough';
const description = 'Request a walkthrough or proposal for commercial cleaning and facility services in San Joaquin Valley. Call (209) 229-2066 or email jcastillo@system4.com.';
const canonicalUrl = 'https://system4sjv.com/contact/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero -->
  <section class="hero" data-animate style="padding:4rem 1.5rem 3rem;">
    <div class="container">
      <h1>Request a Walkthrough<br/>or <em>Proposal</em></h1>
      <p>Tell us about your facility and we'll design a customized cleaning program. For faster quotes, include city, approximate square footage, and service frequency.</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="section" data-animate>
    <div class="container contact-grid">
      <!-- Contact Info -->
      <div>
        <div class="section-label">Get In Touch</div>
        <h2 class="section-title" style="font-size:1.8rem;">System4 of<br/>San Joaquin Valley</h2>

        <div style="margin-top:2rem;">
          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <strong>Phone</strong><br/>
              <a href="tel:+12092292066" class="contact-link">(209) 229-2066</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <strong>Email</strong><br/>
              <a href="mailto:jcastillo@system4.com" class="contact-link">jcastillo@system4.com</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <strong>Service Area</strong><br/>
              <span style="color:var(--gray-500);">Stockton, Modesto, Tracy, Manteca, Lodi, and the greater San Joaquin Valley</span>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <strong>Hours</strong><br/>
              <span style="color:var(--gray-500);">Mon – Fri: 7:00 AM – 8:00 PM<br/>Sat: 8:30 AM – 7:30 PM<br/>Sun: Closed</span>
            </div>
          </div>
        </div>

        <div class="local-badge">
          <strong style="color:var(--green-600);">Locally Owned & Operated</strong>
          <p style="color:var(--gray-700);font-size:.9rem;margin-top:.5rem;line-height:1.6;">The businesses we serve in the community are our friends, family, and neighbors. We treat every facility like it's our own.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h3 style="font-family:var(--font-display);margin-bottom:1.5rem;color:var(--gray-900);">Send Us a Message</h3>
        <form name="contact" data-netlify="true" netlify-honeypot="bot-field" method="POST" action="/contact/thanks/" class="contact-form" aria-label="Contact form">
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <div class="form-row">
            <div class="form-group">
              <label for="first_name">First Name *</label>
              <input type="text" id="first_name" name="first_name" required aria-required="true" autocomplete="given-name" />
            </div>
            <div class="form-group">
              <label for="last_name">Last Name *</label>
              <input type="text" id="last_name" name="last_name" required aria-required="true" autocomplete="family-name" />
            </div>
          </div>
          <div class="form-group">
            <label for="company">Company Name</label>
            <input type="text" id="company" name="company" autocomplete="organization" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required aria-required="true" autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>
          </div>
          <div class="form-group">
            <label for="facility_type">Facility Type</label>
            <select id="facility_type" name="facility_type" aria-label="Select your facility type">
              <option value="">Select one</option>
              <option value="medical_dental">Medical / Dental</option>
              <option value="office">Office / Corporate</option>
              <option value="education">Education</option>
              <option value="showroom">Showroom / Dealership</option>
              <option value="warehouse">Warehouse / Industrial</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Tell Us About Your Needs</label>
            <textarea id="message" name="message" rows="4" placeholder="City, approximate square footage, service frequency, and any special areas..." aria-label="Describe your facility cleaning needs"></textarea>
          </div>
          <button type="submit" class="btn-primary btn-block">Submit Request</button>
          <p style="font-size:.75rem;color:var(--gray-500);text-align:center;margin-bottom:0;">We do not sell your information.</p>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-grid {
    max-width: 1000px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .contact-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #0b7dda, #0a5ea8);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contact-link {
    color: var(--blue);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .local-badge {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--green-100);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--green-600);
  }
  .contact-form-wrap {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
  }
  .form-group label {
    font-size: .85rem;
    font-weight: 600;
    color: var(--gray-700);
    margin-bottom: .25rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: .65rem 1rem;
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-sm);
    font-size: 16px;
    font-family: var(--font-body);
    color: var(--gray-900);
    background: var(--white);
    transition: border-color .2s ease, box-shadow .2s ease;
    width: 100%;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(11, 125, 218, .15);
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--gray-500);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>