---
import Layout from '../layouts/Layout.astro';

const title = 'Commercial Cleaning Services in Stockton & San Joaquin Valley | System4';
const description = 'Professional commercial and office cleaning services in Stockton, Modesto, Tracy, and across the San Joaquin Valley. Customized nightly and daytime cleaning programs for facility managers. Licensed, bonded & insured.';
const canonicalUrl = 'https://system4sjv.com/commercial-cleaning/';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial & Office Cleaning",
  "description": "Professional commercial and office cleaning services for businesses across the San Joaquin Valley, including Stockton, Modesto, Tracy, Manteca, and Lodi.",
  "provider": {
    "@type": "CleaningService",
    "name": "System4 of San Joaquin Valley",
    "telephone": "+1-925-325-8470",
    "url": "https://system4sjv.com"
  },
  "areaServed": [
    {"@type": "City", "name": "Stockton"},
    {"@type": "City", "name": "Modesto"},
    {"@type": "City", "name": "Tracy"},
    {"@type": "City", "name": "Manteca"},
    {"@type": "City", "name": "Lodi"},
    {"@type": "City", "name": "Turlock"}
  ],
  "serviceType": "Commercial Cleaning"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Services", "item": "https://system4sjv.com/services/"},
    {"@type": "ListItem", "position": 3, "name": "Commercial & Office Cleaning"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={[serviceSchema, breadcrumbSchema]}>

  <!-- Hero -->
  <section class="hero" data-animate style="padding:4rem 1.5rem 3rem;position:relative;overflow:hidden;">
    <img src="/images/services-hero.jpg" alt="Commercial cleaning service professionals" class="hero-bg" loading="eager" />
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Commercial Cleaning</div>
      <h1>Commercial & Office Cleaning<br/>in the <em>San Joaquin Valley</em></h1>
      <p>Customized cleaning programs for professional offices, multi-tenant buildings, and commercial spaces across Stockton, Modesto, Tracy, Manteca, and Lodi. Licensed, bonded & insured.</p>
      <div class="hero-cta" style="margin-top:1.5rem;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+19253258470" class="btn-secondary">Call (925) 325-8470</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section" data-animate>
    <div class="container" style="max-width:900px;">
      <div class="section-label" style="text-align:center;">What's Included</div>
      <h2 class="section-title" style="text-align:center;">A Complete Office Cleaning Program</h2>
      <p class="section-subtitle" style="text-align:center;">Every program is customized to your building, your schedule, and your standards. Here's what a typical commercial cleaning program covers:</p>

      <div class="service-detail-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:2.5rem;">
        <div>
          <h3 style="color:var(--gray-900);font-size:1.1rem;margin-bottom:.75rem;">Daily / Nightly Tasks</h3>
          <ul class="service-checklist">
            <li>Trash and recycling removal</li>
            <li>Vacuuming and carpet care</li>
            <li>Mopping hard surface floors</li>
            <li>Dusting desks, shelves, and surfaces</li>
            <li>Break room and kitchen cleaning</li>
            <li>Restroom sanitization and restocking</li>
            <li>Entry and lobby maintenance</li>
            <li>Light fixture and switch plate wiping</li>
          </ul>
        </div>
        <div>
          <h3 style="color:var(--gray-900);font-size:1.1rem;margin-bottom:.75rem;">Periodic / Detail Tasks</h3>
          <ul class="service-checklist">
            <li>Interior window cleaning</li>
            <li>Baseboard and edge detailing</li>
            <li>High-dusting (vents, fixtures, ledges)</li>
            <li>Furniture and upholstery spot treatment</li>
            <li>Door frame and handle sanitization</li>
            <li>Conference room deep cleaning</li>
            <li>Garage and parking area sweeping</li>
            <li>Seasonal deep-clean projects</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why System4 -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:900px;">
      <div class="section-label" style="text-align:center;">Why System4</div>
      <h2 class="section-title" style="text-align:center;">What Makes Us Different</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <h3>One Point of Contact</h3>
          <p>A dedicated territory manager who knows your building, your schedule, and your standards.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>Measured Success® QA</h3>
          <p>Regular inspections with documented results. We catch issues before you do.</p>
        </div>
        <div class="card" data-animate>
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
          <h3>One Invoice</h3>
          <p>Cleaning, maintenance, and repairs — all on one bill. Simple, streamlined, predictable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section" data-animate>
    <div class="container" style="max-width:900px;">
      <div class="section-label" style="text-align:center;">Service Areas</div>
      <h2 class="section-title" style="text-align:center;">Commercial Cleaning Where You Need It</h2>
      <p class="section-subtitle" style="text-align:center;">Daily routes across San Joaquin and Stanislaus Counties. A local team means fast response and real accountability.</p>
      <div class="areas-grid" style="margin-top:2rem;">
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Stockton</strong><br/><span>San Joaquin County — daily routes</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Modesto</strong><br/><span>Stanislaus County — full coverage</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Tracy</strong><br/><span>Fast-growing community — flexible scheduling</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Manteca</strong><br/><span>Central location — fast response times</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Lodi</strong><br/><span>Wine country businesses — specialty care</span></div></div>
        <div class="area-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><div><strong>Turlock</strong><br/><span>Stanislaus County — medical and office focus</span></div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:800px;">
      <div class="section-label" style="text-align:center;">FAQ</div>
      <h2 class="section-title" style="text-align:center;">Common Questions About Commercial Cleaning</h2>
      <div class="faq-list" style="margin-top:2rem;">
        <details class="faq-item">
          <summary class="faq-question">How much does commercial cleaning cost in Stockton?</summary>
          <p class="faq-answer">Pricing depends on square footage, frequency, and scope. Most offices pay between $0.10–$0.25 per square foot per month. We provide free walkthroughs and custom quotes — typically within 24 hours.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Do you require long-term contracts?</summary>
          <p class="faq-answer">No. System4 works on a month-to-month basis. We believe you should stay because the service is great, not because a contract forces you to.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Can you clean after business hours?</summary>
          <p class="faq-answer">Yes. Most of our clients prefer nightly cleaning after hours. We can also provide daytime porter service for high-traffic facilities.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">What's included in a standard office cleaning?</summary>
          <p class="faq-answer">Trash removal, vacuuming, mopping, dusting, restroom sanitization, break room cleaning, and entry/lobby maintenance. We customize every checklist to your priorities.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" data-animate>
    <img src="/images/cta-meeting.jpg" alt="Office walkthrough meeting" class="cta-bg" loading="lazy" />
    <div class="container" style="position:relative;z-index:1;">
      <h2>Ready for a Cleaner Office?</h2>
      <p>Get a free walkthrough and customized cleaning program. We'll assess your space, identify your needs, and deliver a proposal — typically within 24 hours.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+19253258470" class="btn-secondary">Call (925) 325-8470</a>
        <a href="mailto:jcastillo@system4.com" class="btn-secondary">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .service-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .service-checklist { list-style: none; padding: 0; }
  .service-checklist li { padding: .5rem 0 .5rem 1.5rem; position: relative; color: var(--gray-700); font-size: .95rem; line-height: 1.6; }
  .service-checklist li::before { content: '✓'; position: absolute; left: 0; color: var(--green-600); font-weight: 700; }
  .faq-item { border: 1px solid var(--gray-100); border-radius: var(--radius-md); padding: 1.25rem; margin-bottom: 1rem; background: white; }
  .faq-question { font-weight: 600; cursor: pointer; color: var(--gray-900); font-size: 1rem; list-style: none; display: flex; align-items: center; justify-content: space-between; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; font-size: 1.2rem; font-weight: 300; color: var(--blue); transition: transform .2s ease; }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer { color: var(--gray-500); margin-top: .75rem; line-height: 1.7; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .areas-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .area-card { background: var(--white); border: 1px solid var(--gray-100); border-radius: var(--radius-md); padding: 1.25rem 1.5rem; display: flex; align-items: center; gap: .75rem; transition: all .3s ease; box-shadow: 0 1px 3px rgba(0,0,0,.04); }
  .area-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); transform: translateX(4px); }
  .area-card svg { color: var(--green-600); flex-shrink: 0; }
  .area-card strong { color: var(--gray-900); font-size: 1rem; }
  .area-card span { color: var(--gray-500); font-size: .85rem; }
  @media (max-width: 768px) {
    .service-detail-grid { grid-template-columns: 1fr; }
    .areas-grid { grid-template-columns: 1fr; }
    .cta-buttons { flex-direction: column; align-items: stretch; }
    .cta-buttons a { text-align: center; justify-content: center; }
  }
</style>