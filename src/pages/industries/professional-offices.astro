---
import Layout from '../../layouts/Layout.astro';

const title = 'Professional Office Cleaning | System4 of San Joaquin Valley';
const description = 'Commercial cleaning for professional offices, coworking spaces, and multi-tenant buildings in San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/professional-offices/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <section class="hero" data-animate style="padding:4rem 1.5rem 3rem;">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Office & Corporate</div>
      <h1>Professional Office<br/><em>Cleaning Services</em></h1>
      <p>Keep your workspace spotless and your team productive with customized office cleaning programs.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">A Clean Office Is a Productive Office</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Your office is the first impression clients and employees have of your business. System4 builds cleaning programs around your operating hours, traffic patterns, and priorities — so your space always looks its best.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Office Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Workstations & Desks</h3>
          <p>Dusting, sanitizing, and trash removal for individual workstations and shared desks.</p>
        </div>
        <div class="card" data-animate>
          <h3>Break Rooms & Kitchens</h3>
          <p>Countertops, appliances, sinks, floors, and trash — keep common areas clean and welcoming.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Full sanitization, supply restocking, and fixture cleaning on every visit.</p>
        </div>
        <div class="card" data-animate>
          <h3>Lobbies & Reception</h3>
          <p>First impressions matter — glass, floors, seating, and entryways kept client-ready.</p>
        </div>
        <div class="card" data-animate>
          <h3>Floor Care</h3>
          <p>Vacuuming, mopping, and scheduled hard floor maintenance programs.</p>
        </div>
        <div class="card" data-animate>
          <h3>High-Touch Points</h3>
          <p>Door handles, light switches, elevator buttons, and shared surfaces disinfected regularly.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <div class="section-label" style="text-align:center;">Why System4</div>
      <h2 class="section-title" style="text-align:center;">Built for Office Managers & Facility Teams</h2>
      <ul style="list-style:none;padding:0;margin-top:2rem;">
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>One point of contact</strong> — Your dedicated account manager handles everything</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>One invoice</strong> — All services on a single, predictable bill</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Measured Success® QA</strong> — Documented inspections every visit</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Nightly or daytime</strong> — Programs built around your operating hours</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>No long-term contracts</strong> — Service adapts as your needs change</span></li>
      </ul>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Get a Customized Office Cleaning Program</h2>
      <p>Tell us about your space and we'll build a program that fits your schedule and budget.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>