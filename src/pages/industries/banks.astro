---
import Layout from '../../layouts/Layout.astro';

const title = 'Bank & Financial Office Cleaning | System4 of San Joaquin Valley';
const description = 'Security-conscious cleaning for banks, credit unions, and financial offices across San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/banks/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <section class="hero" data-animate style="padding:4rem 1.5rem 3rem;">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Financial</div>
      <h1>Banks &<br/><em>Financial Offices</em></h1>
      <p>Detail-oriented, security-conscious cleaning for high-traffic customer environments.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Clean Spaces Build Client Trust</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Banks and financial institutions require a cleaning partner that respects security protocols, operates discreetly during business hours, and delivers consistent results. System4's vetted, insured providers understand the demands of financial environments.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Financial Facility Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Lobbies & Teller Areas</h3>
          <p>High-visibility, high-traffic cleaning that keeps customer-facing spaces spotless.</p>
        </div>
        <div class="card" data-animate>
          <h3>Private Offices</h3>
          <p>Discreet after-hours cleaning for executive and loan offices with sensitive materials.</p>
        </div>
        <div class="card" data-animate>
          <h3>ATM Vestibules</h3>
          <p>Screen cleaning, surface disinfection, and floor care for 24/7 access areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Break Rooms</h3>
          <p>Countertops, appliances, floors, and trash for employee common areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Full sanitization and restocking for customer and employee restrooms.</p>
        </div>
        <div class="card" data-animate>
          <h3>Floor Care</h3>
          <p>Hard floor maintenance, carpet care, and entrance mat programs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Clean Facilities, Confident Clients</h2>
      <p>Get a security-conscious cleaning program for your bank or financial office.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>