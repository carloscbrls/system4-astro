---
import Layout from '../../layouts/Layout.astro';

const title = 'Bank & Financial Office Cleaning in Stockton, CA | System4 SJV';
const description = 'Security-conscious commercial cleaning for banks, credit unions, and financial offices across Stockton, Modesto, Tracy, and the San Joaquin Valley. Licensed, bonded & insured.';
const canonicalUrl = 'https://system4sjv.com/industries/banks/';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Bank & Financial Office Cleaning",
  "description": "Security-conscious commercial cleaning for banks, credit unions, and financial offices across the San Joaquin Valley, including Stockton, Modesto, Tracy, Manteca, and Lodi.",
  "provider": {
    "@type": "CleaningService",
    "name": "System4 of San Joaquin Valley",
    "telephone": "+1-209-229-2066",
    "url": "https://system4sjv.com"
  },
  "areaServed": [
    {"@type": "City", "name": "Stockton"},
    {"@type": "City", "name": "Modesto"},
    {"@type": "City", "name": "Tracy"},
    {"@type": "City", "name": "Manteca"},
    {"@type": "City", "name": "Lodi"},
    {"@type": "City", "name": "Turlock"}
  ],
  "serviceType": "Bank & Financial Office Cleaning"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Industries", "item": "https://system4sjv.com/industries/"},
    {"@type": "ListItem", "position": 3, "name": "Banks & Financial Offices"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={[serviceSchema, breadcrumbSchema]}>

  <section class="hero" data-animate style="padding:4rem 1.5rem 3rem;position:relative;overflow:hidden;">
    <img src="/images/industry-bank.jpg" alt="Clean bank branch lobby" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.15;pointer-events:none;" loading="eager" />
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Financial</div>
      <h1>Banks &<br/><em>Financial Offices</em></h1>
      <p>Detail-oriented, security-conscious cleaning for high-traffic customer environments across Stockton, Modesto, Tracy, Manteca, and Lodi. Licensed, bonded & insured.</p>
      <div class="hero-cta" style="margin-top:1.5rem;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Clean Spaces Build Client Trust</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Banks and financial institutions require a cleaning partner that respects security protocols, operates discreetly during business hours, and delivers consistent results. System4's vetted, insured providers understand the demands of financial environments.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Financial Facility Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Lobbies & Teller Areas</h3>
          <p>High-visibility, high-traffic cleaning that keeps customer-facing spaces spotless.</p>
        </div>
        <div class="card" data-animate>
          <h3>Private Offices</h3>
          <p>Discreet after-hours cleaning for executive and loan offices with sensitive materials.</p>
        </div>
        <div class="card" data-animate>
          <h3>ATM Vestibules</h3>
          <p>Screen cleaning, surface disinfection, and floor care for 24/7 access areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Break Rooms</h3>
          <p>Countertops, appliances, floors, and trash for employee common areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Full sanitization and restocking for customer and employee restrooms.</p>
        </div>
        <div class="card" data-animate>
          <h3>Floor Care</h3>
          <p>Hard floor maintenance, carpet care, and entrance mat programs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Clean Facilities, Confident Clients</h2>
      <p>Get a security-conscious cleaning program for your bank or financial office.</p>
      <div class="cta-buttons" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
        <a href="mailto:jcastillo@system4.com" class="btn-secondary">Email jcastillo@system4.com</a>
      </div>
    </div>
  </section>

</Layout>