---
import Layout from '../../layouts/Layout.astro';

const title = 'Dealership & Showroom Cleaning | System4 of San Joaquin Valley';
const description = 'Presentation-focused cleaning for auto dealerships, showrooms, and customer-facing spaces across San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/dealerships/';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Dealership & Showroom Cleaning",
  "description": "Presentation-focused cleaning for auto dealerships, showrooms, and customer-facing spaces across San Joaquin and Stanislaus counties.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "System4 San Joaquin Valley",
    "telephone": "+1-209-229-2066",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockton",
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": [
      {"@type": "City", "name": "Stockton"},
      {"@type": "City", "name": "Modesto"},
      {"@type": "City", "name": "Tracy"},
      {"@type": "City", "name": "Manteca"},
      {"@type": "City", "name": "Lodi"},
      {"@type": "City", "name": "Turlock"}
    ]
  },
  "url": "https://system4sjv.com/industries/dealerships/"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Industries", "item": "https://system4sjv.com/industries/"},
    {"@type": "ListItem", "position": 3, "name": "Dealership & Showroom Cleaning", "item": "https://system4sjv.com/industries/dealerships/"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={[serviceSchema, breadcrumbSchema]}>

  <section class="hero hero-compact" data-animate>
    <img src="/images/dealerships-hero.jpg" alt="Clean car dealership showroom" class="hero-bg" loading="eager" />
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Dealerships</div>
      <h1>Dealership &<br/><em>Showroom Cleaning</em></h1>
      <p>Presentation-focused cleaning that helps your showroom shine and your customers feel confident.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Showroom Standards for Every Space</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Dealerships and showrooms demand a different level of clean. Customers judge your business the moment they walk through the door. System4 delivers consistent, detail-oriented cleaning that keeps every surface, floor, and fixture looking its best.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Dealership Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Showroom Floors</h3>
          <p>High-shine floor maintenance, spot cleaning, and scheduled care programs for showroom tiles and finishes.</p>
        </div>
        <div class="card" data-animate>
          <h3>Customer Lounges</h3>
          <p>Coffee bars, seating areas, restrooms, and waiting spaces kept client-ready at all times.</p>
        </div>
        <div class="card" data-animate>
          <h3>Service Drive & Bays</h3>
          <p>Floor cleaning, oil spot treatment, and common area maintenance for service departments.</p>
        </div>
        <div class="card" data-animate>
          <h3>Offices & F&I</h3>
          <p>Professional cleaning for sales offices, finance rooms, and administrative areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Full sanitization and supply restocking for customer and employee restrooms.</p>
        </div>
        <div class="card" data-animate>
          <h3>Exterior & Entry</h3>
          <p>Window cleaning, entry maintenance, and parking area coordination.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Make Every First Impression Count</h2>
      <p>Get a showroom-quality cleaning program tailored to your dealership.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>