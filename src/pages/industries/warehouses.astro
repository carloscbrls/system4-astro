---
import Layout from '../../layouts/Layout.astro';

const title = 'Warehouse & Industrial Cleaning | System4 of San Joaquin Valley';
const description = 'Practical cleaning for warehouses, distribution centers, and light industrial facilities across San Joaquin and Stanislaus counties.';
const canonicalUrl = 'https://system4sjv.com/industries/warehouses/';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Warehouse & Industrial Cleaning",
  "description": "Practical cleaning for warehouses, distribution centers, and light industrial facilities across San Joaquin and Stanislaus counties.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "System4 San Joaquin Valley",
    "telephone": "+1-209-229-2066",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockton",
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": [
      {"@type": "City", "name": "Stockton"},
      {"@type": "City", "name": "Modesto"},
      {"@type": "City", "name": "Tracy"},
      {"@type": "City", "name": "Manteca"},
      {"@type": "City", "name": "Lodi"},
      {"@type": "City", "name": "Turlock"}
    ]
  },
  "url": "https://system4sjv.com/industries/warehouses/"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Industries", "item": "https://system4sjv.com/industries/"},
    {"@type": "ListItem", "position": 3, "name": "Warehouse & Industrial Cleaning", "item": "https://system4sjv.com/industries/warehouses/"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={[serviceSchema, breadcrumbSchema]}>

  <section class="hero hero-compact" data-animate>
    <img src="/images/warehouses-hero.jpg" alt="Clean warehouse and industrial facility" class="hero-bg" loading="eager" />
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Industrial</div>
      <h1>Warehouse &<br/><em>Industrial Cleaning</em></h1>
      <p>Practical cleaning solutions for back-of-house environments that keep operations running.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Clean Facilities Run Better</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Warehouses and industrial facilities have different cleaning needs than office spaces — heavier soil, larger floor areas, and a focus on safety and compliance. System4 builds practical programs that address real conditions without unnecessary frills.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Industrial Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Floor Care</h3>
          <p>Concrete scrubbing, epoxy maintenance, and scheduled hard floor programs for safety and appearance.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms & Break Rooms</h3>
          <p>Full sanitization, supply restocking, and fixture cleaning for employee areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Loading Docks</h3>
          <p>Sweeping, debris removal, and surface cleaning for dock areas and shipping lanes.</p>
        </div>
        <div class="card" data-animate>
          <h3>Office & Administrative</h3>
          <p>Professional cleaning for front offices, conference rooms, and admin areas within the facility.</p>
        </div>
        <div class="card" data-animate>
          <h3>Common Areas</h3>
          <p>Lobbies, hallways, and shared spaces kept clean for employees and visitors.</p>
        </div>
        <div class="card" data-animate>
          <h3>Exterior & Grounds</h3>
          <p>Parking lot sweeping, entrance maintenance, and grounds coordination.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Get a Practical Cleaning Program for Your Facility</h2>
      <p>We address real conditions without unnecessary frills. Tell us about your space.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>