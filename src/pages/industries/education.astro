---
import Layout from '../../layouts/Layout.astro';

const title = 'Education & School Cleaning | System4 of San Joaquin Valley';
const description = 'Cleaning services for schools, colleges, and educational facilities across San Joaquin and Stanislaus counties. Disinfection programs that keep students and staff safe.';
const canonicalUrl = 'https://system4sjv.com/industries/education/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>

  <section class="hero hero-compact" data-animate>
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Education</div>
      <h1>Education &<br/><em>School Cleaning</em></h1>
      <p>Cleaning programs for schools, colleges, and educational facilities that keep students and staff safe.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">Clean Schools Start With Consistent Service</h2>
      <p style="color:var(--gray-500);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Educational facilities face high traffic, tight budgets, and a community that expects visible cleanliness. System4 builds programs around school calendars, class schedules, and seasonal needs — from daily disinfection to summer deep-cleaning.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container">
      <div class="section-label">What We Cover</div>
      <h2 class="section-title">Full-Scope Education Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Classrooms & Labs</h3>
          <p>Desk surfaces, whiteboards, floors, and high-touch disinfection between classes.</p>
        </div>
        <div class="card" data-animate>
          <h3>Hallways & Common Areas</h3>
          <p>High-traffic flooring, lockers, drinking fountains, and entranceways.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Full sanitization, supply restocking, and fixture cleaning on every visit.</p>
        </div>
        <div class="card" data-animate>
          <h3>Gymnasiums & Locker Rooms</h3>
          <p>Floor care, disinfection, and odor control for athletic facilities.</p>
        </div>
        <div class="card" data-animate>
          <h3>Cafeterias & Break Rooms</h3>
          <p>Food-safe cleaning, surface sanitization, and floor maintenance.</p>
        </div>
        <div class="card" data-animate>
          <h3>Administrative Offices</h3>
          <p>Professional office cleaning for front offices, staff rooms, and admin areas.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Cleaner Schools, Healthier Students</h2>
      <p>We build programs around school calendars and budgets. Get a walkthrough and customized proposal.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact/" class="btn-primary">Request a Walkthrough</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>