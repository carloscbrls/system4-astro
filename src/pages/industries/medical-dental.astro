---
import Layout from '../../layouts/Layout.astro';

const title = 'Medical & Dental Office Cleaning | System4 of San Joaquin Valley';
const description = 'System4 provides healthcare-focused cleaning for medical centers, dental offices, and clinics across San Joaquin and Stanislaus counties. Infection-control best practices, EPA-approved products.';
const canonicalUrl = 'https://system4sjv.com/industries/medical-dental/';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Medical & Dental Office Cleaning",
  "description": "System4 provides healthcare-focused cleaning for medical centers, dental offices, and clinics across San Joaquin and Stanislaus counties. Infection-control best practices, EPA-approved products.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "System4 San Joaquin Valley",
    "telephone": "+1-209-229-2066",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockton",
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": [
      {"@type": "City", "name": "Stockton"},
      {"@type": "City", "name": "Modesto"},
      {"@type": "City", "name": "Tracy"},
      {"@type": "City", "name": "Manteca"},
      {"@type": "City", "name": "Lodi"},
      {"@type": "City", "name": "Turlock"}
    ]
  },
  "url": "https://system4sjv.com/industries/medical-dental/"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://system4sjv.com/"},
    {"@type": "ListItem", "position": 2, "name": "Industries", "item": "https://system4sjv.com/industries/"},
    {"@type": "ListItem", "position": 3, "name": "Medical & Dental Office Cleaning", "item": "https://system4sjv.com/industries/medical-dental/"}
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={[serviceSchema, breadcrumbSchema]}>

  <section class="hero hero-compact" data-animate>
    <img src="/images/medical-dental-hero.jpg" alt="Clean medical office examination room" class="hero-bg" loading="eager" />
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,.8);text-align:center;">Healthcare Facilities</div>
      <h1>Medical & Dental<br/><em>Office Cleaning</em></h1>
      <p>Facility services for medical centers that protect patients, staff, and your reputation.</p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <h2 class="section-title" style="text-align:center;">A Higher Standard of Clean</h2>
      <p style="color:var(--gray-700);-webkit-text-fill-color:var(--gray-700);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Medical centers carry a higher standard of cleanliness than almost any other facility type. Patients and their families in a vulnerable situation need a visibly clean, well-maintained environment that gives them confidence they're in the right hands.</p>
      <p style="color:var(--gray-700);-webkit-text-fill-color:var(--gray-700);font-size:1.05rem;line-height:1.8;text-align:center;margin-top:1rem;">Behind the scenes, proper disinfection protocols protect staff, reduce infection risk, and keep your facility in compliance. System4 provides commercial cleaning and facility services built for the demands of medical environments.</p>
    </div>
  </section>

  <section class="section section-alt" data-animate>
    <div class="container" style="max-width:960px;">
      <div class="section-label" style="text-align:center;">What We Cover</div>
      <h2 class="section-title" style="text-align:center;">Full-Scope Healthcare Cleaning</h2>
      <div class="card-grid card-grid-3" style="margin-top:2.5rem;">
        <div class="card" data-animate>
          <h3>Exam & Treatment Areas</h3>
          <p>Exam room and treatment area cleaning and terminal disinfection between patients.</p>
        </div>
        <div class="card" data-animate>
          <h3>Waiting Rooms</h3>
          <p>Reception area cleaning and disinfecting — high-touch surfaces, seating, and check-in kiosks.</p>
        </div>
        <div class="card" data-animate>
          <h3>Restrooms</h3>
          <p>Sanitizing and supply restocking for patient and staff restrooms.</p>
        </div>
        <div class="card" data-animate>
          <h3>High-Touch Points</h3>
          <p>Door handles, push plates, rails, switches, counters — the points everyone touches.</p>
        </div>
        <div class="card" data-animate>
          <h3>Floor Care</h3>
          <p>Hard floor maintenance and carpet cleaning in administrative areas.</p>
        </div>
        <div class="card" data-animate>
          <h3>Facility Support</h3>
          <p>Medical waste area support, HVAC maintenance, and building repair coordination.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container" style="max-width:800px;">
      <div class="section-label" style="text-align:center;">Why System4</div>
      <h2 class="section-title" style="text-align:center;">Why Choose System4 for Your Medical Facility</h2>
      <ul style="list-style:none;padding:0;margin-top:2rem;">
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Healthcare-grade cleaning protocols:</strong> Providers trained on infection control and clinical disinfection standards</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>EPA-approved products:</strong> The right disinfectants for patient-facing and clinical spaces</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Assigned account manager:</strong> One contact managing your entire program with knowledge of your compliance requirements</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Measured Success® QA program:</strong> Documented inspection reporting for every cleaning visit</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Pre-screened, fully insured providers:</strong> Vetted professionals who meet System4's standards for reliability and clinical professionalism</span></li>
        <li style="display:flex;align-items:flex-start;gap:.75rem;margin-bottom:1rem;"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-600)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>No long-term contracts:</strong> Service programs that adapt as your facility's needs change</span></li>
      </ul>
    </div>
  </section>

  <section class="cta-section" data-animate>
    <div class="container">
      <h2>Get a Customized Cleaning Program for Your Medical Facility</h2>
      <p>We understand the demands of healthcare environments. Let us build a program that keeps your patients, staff, and reputation protected.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+12092292066" class="btn-secondary">Call (209) 229-2066</a>
      </div>
    </div>
  </section>

</Layout>